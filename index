<!DOCTYPE html>
<html>
  <head>
    <base target="_top">
    <!-- Adicionado para melhorar comportamento mobile/fullscreen -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="mobile-web-app-capable" content="yes">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/html5-qrcode"></script>
    <!-- Biblioteca para gerar PDF -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Ícones -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <style>
      :root {
        --verde-intelbras: #00AA4E;
        --verde-escuro: #008f41;
        --verde-claro-bg: #e8f5e9;
        --azul-corretiva: #0056b3;
        --azul-bg-suave: #e3f2fd;
        --texto-escuro: #2c3e50;
        --texto-cinza: #636e72;
        --vermelho-nok: #dc3545;
        --cinza-na: #95a5a6;
        --fundo-pagina: #1e1e24;
        
        /* Sombras Modernas */
        --sombra-card: 0 20px 50px rgba(0,0,0,0.3);
        --sombra-btn: 0 4px 15px rgba(0, 170, 78, 0.25);
        --sombra-hover: 0 8px 25px rgba(0, 170, 78, 0.35);
        --border-radius-card: 28px;
        --border-radius-elem: 16px;
      }

      body { 
        background: radial-gradient(circle at top center, #2b2b36 0%, #121214 100%);
        font-family: 'Poppins', sans-serif; 
        display: flex; justify-content: center; align-items: center; 
        min-height: 100vh; margin: 0; padding: 20px;
        color: var(--texto-escuro);
      }

      /* Força o iOS a reconhecer elementos como clicáveis e resolve delays de touch */
      button, .btn-status, .toggle-peca, .machine-bubble, .btn-voltar, .btn-camera-small, [onclick] {
          cursor: pointer;
          touch-action: manipulation;
      }

      /* Otimização essencial para o clique da câmera no Chrome/Safari iOS */
      input[type="file"].hidden, input[type="file"][style*="display:none"], input[type="file"][style*="display: none"] {
          display: block !important;
          position: absolute !important;
          opacity: 0 !important;
          width: 1px !important;
          height: 1px !important;
          z-index: -1 !important;
          top: 0;
      }

      /* Container Principal Expandido para Tablets */
      .container-card { 
        background: #ffffff; 
        padding: 40px; 
        border-radius: var(--border-radius-card); 
        box-shadow: var(--sombra-card); 
        width: 100%; 
        max-width: 680px; /* Aumentado para tablets */
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* Otimizado de 0.4s para 0.2s */
        position: relative;
        overflow: hidden;
      }

      /* Header Minimalista */
      .logo-container { text-align: center; margin-bottom: 35px; }
      
      /* Estilo da Logo Principal na Tela */
      .main-logo {
        max-width: 220px; /* Tamanho controlado */
        height: auto;
        display: inline-block;
        margin-bottom: 5px;
      }

      .logo-container p {
        color: var(--texto-cinza);
        font-size: 14px;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 0px;
        font-weight: 500;
      }

      /* Inputs Modernos */
      .form-label { font-weight: 600; color: var(--texto-escuro); margin-bottom: 8px; font-size: 15px; }
      .form-label-small { font-size: 13px; font-weight: 600; color: var(--texto-cinza); margin-bottom: 6px; display: block; text-transform: uppercase; letter-spacing: 0.5px; }
      
      .form-select, .form-control, .input-corr, .obs-input { 
        border: 2px solid #f0f2f5;
        background-color: #f8f9fa;
        border-radius: var(--border-radius-elem);
        padding: 16px 20px;
        font-size: 15px;
        color: var(--texto-escuro);
        transition: all 0.3s ease;
        width: 100%;
        box-shadow: none;
      }
      
      .form-select:focus, .form-control:focus, .input-corr:focus, .obs-input:focus {
        border-color: var(--verde-intelbras);
        background-color: #fff;
        box-shadow: 0 0 0 4px rgba(0, 170, 78, 0.1);
        outline: none;
      }

      /* Botão Principal Estiloso */
      .btn-main {
        background: linear-gradient(135deg, var(--verde-intelbras) 0%, var(--verde-escuro) 100%);
        color: white; border: none; 
        padding: 18px; 
        border-radius: var(--border-radius-elem); 
        font-weight: 700; 
        width: 100%; 
        margin-top: 20px; 
        font-size: 16px; 
        letter-spacing: 0.5px;
        transition: transform 0.15s, box-shadow 0.15s; /* Acelerado para 0.15s */
        display: flex; align-items: center; justify-content: center; gap: 12px;
        box-shadow: var(--sombra-btn);
        text-transform: uppercase;
      }
      .btn-main:hover:not(:disabled) { transform: translateY(-2px); box-shadow: var(--sombra-hover); }
      .btn-main:active { transform: translateY(1px); }
      .btn-main:disabled { background: #dcdcdc; cursor: not-allowed; box-shadow: none; transform: none; color: #999; }

      .btn-blue { 
        background: linear-gradient(135deg, #2196f3 0%, #0d47a1 100%); 
        box-shadow: 0 4px 15px rgba(33, 150, 243, 0.3);
      }
      .btn-blue:hover:not(:disabled) { box-shadow: 0 8px 25px rgba(33, 150, 243, 0.4); }
      
      .btn-gray { 
        background: #f1f2f6; 
        color: var(--texto-escuro); 
        box-shadow: none; 
      }
      .btn-gray:hover { background: #e2e4ea; transform: translateY(-2px); }

      .hidden { display: none !important; }

      /* Leitor QR */
      #reader { 
        border-radius: 20px; 
        overflow: hidden; 
        border: 4px solid var(--verde-intelbras) !important; 
        background: #000; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        display: none; /* Escondido por padrão agora */
      }

      /* Badges e Status */
      .status-badge {
        background-color: var(--verde-claro-bg); 
        color: var(--verde-escuro); 
        padding: 8px 20px;
        border-radius: 50px; 
        font-size: 0.9rem; 
        display: inline-block; 
        margin-bottom: 20px; 
        font-weight: 700;
        letter-spacing: 0.5px;
      }

      /* KPI Dashboard */
      .kpi-container { display: flex; justify-content: space-between; gap: 15px; margin-bottom: 25px; }
      .kpi-box { 
        background: #ffffff; 
        border-radius: 18px; 
        padding: 15px; 
        text-align: center; 
        flex: 1; 
        border: 1px solid #f0f0f0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
        position: relative;
        overflow: hidden;
      }
      .kpi-box::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--azul-corretiva); }
      .kpi-title { font-size: 11px; text-transform: uppercase; color: #999; margin-bottom: 5px; font-weight: 700; letter-spacing: 1px; }
      .kpi-value { font-size: 20px; font-weight: 800; color: var(--texto-escuro); }

      /* Tabela Histórico */
      .table-wrapper { 
        max-height: 300px; 
        overflow-y: auto; 
        font-size: 13px; 
        border: 1px solid #f0f0f0; 
        border-radius: 16px; 
        box-shadow: 0 5px 15px rgba(0,0,0,0.02);
      }
      .table thead th { 
        background-color: #f8f9fa; 
        border-bottom: 2px solid #eee; 
        padding: 12px; 
        font-weight: 600; 
        color: #555; 
        position: sticky; top: 0; z-index: 1;
      }
      .table td { padding: 12px; vertical-align: middle; border-bottom: 1px solid #f9f9f9; }
      .row-clickable { cursor: pointer; transition: background 0.2s; }
      .row-clickable:hover { background-color: var(--verde-claro-bg) !important; }

      /* Botões de Seleção (Grid Moderno) */
      .btn-status-group { 
        display: flex; 
        gap: 12px; 
        justify-content: center; 
        margin-bottom: 25px; 
        flex-wrap: wrap; /* Permitir quebra de linha para muitos botões */
      }
      .btn-status { 
        flex: 1 1 140px; /* Base de 140px, cresce para preencher */
        padding: 18px 10px; 
        border-radius: 18px; 
        border: 2px solid #eee; 
        background: white; 
        color: var(--texto-cinza); 
        font-weight: 600; 
        font-size: 13px;
        display: flex; flex-direction: column; align-items: center; gap: 8px;
        transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
        cursor: pointer;
      }
      .btn-status:hover { border-color: #ddd; transform: translateY(-2px); }
      .btn-status i { font-size: 24px; transition: 0.3s; }
      
      /* Estados Selecionados */
      .btn-status.selected-ok { background-color: var(--verde-intelbras); color: white; border-color: var(--verde-intelbras); box-shadow: 0 5px 15px rgba(0,170,78,0.3); }
      .btn-status.selected-nok { background-color: var(--vermelho-nok); color: white; border-color: var(--vermelho-nok); box-shadow: 0 5px 15px rgba(220,53,69,0.3); }
      .btn-status.selected-na { background-color: var(--cinza-na); color: white; border-color: var(--cinza-na); }

      /* Área de Extras e Fotos (Melhorada para ocultar/exibir) */
      .extras-container { 
        background: #fbfbfb; 
        padding: 20px; 
        border-radius: 20px; 
        margin-bottom: 20px; 
        border: 2px dashed #eee; 
        display: none; /* Começa oculto */
        animation: slideDown 0.2s ease forwards;
      }
      .extras-container.show { display: block; }
      
      .photo-section { display: flex; gap: 12px; margin-top: 15px; flex-wrap: wrap; }
      .photo-item { flex: 1; min-width: 100px; text-align: center; }
      
      .photo-preview { 
        width: 100%; height: 120px; object-fit: cover; border-radius: 12px; 
        display: none; border: 3px solid var(--verde-intelbras); margin-bottom: 8px; 
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }
      .photo-preview.active { display: block; animation: popIn 0.2s ease; }
      
      .btn-camera-small { 
        font-size: 13px; padding: 12px; width: 100%; 
        border-radius: 12px; border: 2px dashed #ccc; color: #555; background: #fff;
        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; font-weight: 600;
        transition: 0.2s; height: 100%;
        cursor: pointer;
      }
      .btn-camera-small i { font-size: 20px; color: var(--verde-intelbras); }
      .btn-camera-small:hover { border-color: var(--verde-intelbras); background: var(--verde-claro-bg); }
      
      .btn-remove-photo { 
        font-size: 12px; color: var(--vermelho-nok); cursor: pointer; 
        margin-top: 5px; display: none; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
      }
      .btn-remove-photo.active { display: block; }

      .extra-photos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 10px; margin-top: 15px; }
      .extra-photo-container { position: relative; }
      .img-extra-thumb { width: 100%; height: 80px; object-fit: cover; border-radius: 12px; border: 1px solid #eee; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
      .extra-photo-caption {
        margin-top: 6px;
        font-size: 11px;
        line-height: 1.35;
        color: var(--texto-cinza);
        text-align: left;
        word-break: break-word;
      }
      .btn-remove-extra { 
        position: absolute; top: -8px; right: -8px; 
        background: var(--vermelho-nok); color: white; 
        border-radius: 50%; width: 24px; height: 24px; 
        font-size: 12px; display: flex; align-items: center; justify-content: center; 
        border: 2px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        cursor: pointer;
      }

      /* Navegação Wizard */
      .step-question { font-size: 1.2rem; font-weight: 700; text-align: center; margin-bottom: 25px; line-height: 1.4; color: var(--texto-escuro); }
      .step-counter { font-size: 11px; text-transform: uppercase; font-weight: 700; color: var(--texto-cinza); letter-spacing: 1px; text-align: center; margin-bottom: 8px; }

      .btn-nav-group { display: flex; justify-content: space-between; margin-top: 30px; border-top: 1px solid #f0f0f0; padding-top: 20px; }
      .btn-nav { background: none; border: none; color: #999; font-size: 15px; font-weight: 600; display: flex; align-items: center; gap: 8px; padding: 10px 15px; border-radius: 10px; transition: 0.2s; }
      .btn-nav:hover:not(:disabled) { background: #f5f5f5; color: #555; }
      .btn-nav:disabled { opacity: 0.4; cursor: not-allowed; }
      .btn-next { color: var(--verde-intelbras); }
      .btn-next:hover:not(:disabled) { background: var(--verde-claro-bg); color: var(--verde-escuro); }

      /* --- MODAIS CORRIGIDOS PARA TABLET --- */
      
      /* Modal de Senha */
      #modalSenha { 
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.9); z-index: 11000; 
        display: none; justify-content: center; align-items: center; padding: 20px;
        backdrop-filter: blur(5px);
      }
      #modalSenha.show { display: flex; }
      .senha-card { 
        background: white; border-radius: 20px; width: 100%; max-width: 350px; 
        overflow: hidden; animation: slideDown 0.2s ease; 
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
      }
      .senha-header { background: var(--verde-intelbras); color: white; padding: 25px; text-align: center; }
      .senha-body { padding: 30px 25px; text-align: center; }
      .senha-footer { padding: 20px; display: flex; gap: 10px; background: #f8f9fa; }
      .input-senha { 
        width: 100%; padding: 15px; border: 2px solid #eee; border-radius: 12px; 
        font-size: 24px; text-align: center; letter-spacing: 8px; margin-bottom: 5px; 
        font-weight: 700; color: var(--texto-escuro);
      }
      .input-senha:focus { border-color: var(--verde-intelbras); outline: none; }

      /* Modal de Alerta */
      #intelbrasAlertaModal { 
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.8); z-index: 12000; 
        display: none; justify-content: center; align-items: center; padding: 20px;
        backdrop-filter: blur(2px);
      }
      #intelbrasAlertaModal.show { display: flex; }
      .alerta-card { 
        background: white; border-radius: 20px; width: 100%; max-width: 400px; 
        overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.4); 
        transform: scale(0.9); opacity: 0; transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1); 
      }
      #intelbrasAlertaModal.show .alerta-card { transform: scale(1); opacity: 1; }
      .alerta-header { padding: 20px; text-align: center; color: white; background: var(--verde-intelbras); }
      .alerta-header i { font-size: 40px; margin-bottom: 10px; display: block; }
      .alerta-body { padding: 30px; text-align: center; color: #555; font-size: 16px; line-height: 1.5; }
      .alerta-footer { padding: 15px; display: flex; justify-content: center; background: #f8f9fa; }
      .btn-alerta-ok { 
        background: var(--verde-intelbras); color: white; border: none; 
        padding: 12px 40px; border-radius: 10px; font-weight: 700; 
        cursor: pointer; transition: 0.2s; 
      }
      .alerta-card.alerta-error .alerta-header { background: var(--vermelho-nok); }
      .alerta-card.alerta-error .btn-alerta-ok { background: var(--vermelho-nok); }
      .alerta-card.alerta-info .alerta-header { background: var(--azul-corretiva); }
      .alerta-card.alerta-info .btn-alerta-ok { background: var(--azul-corretiva); }

      .comentario-foto-body {
        padding: 24px;
      }
      .comentario-foto-body p {
        margin-bottom: 14px;
        color: var(--texto-cinza);
        text-align: center;
        font-size: 14px;
      }
      .comentario-foto-textarea {
        min-height: 110px;
        resize: vertical;
        border-radius: 16px;
        border: 2px solid #eef0f3;
        background: #f8f9fa;
        padding: 16px 18px;
        font-size: 14px;
        color: var(--texto-escuro);
        width: 100%;
        transition: all 0.2s ease;
      }
      .comentario-foto-textarea:focus {
        outline: none;
        border-color: var(--azul-corretiva);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(0, 86, 179, 0.1);
      }
      .comentario-foto-textarea.input-invalido {
        border-color: var(--vermelho-nok);
        background: #fff5f5;
        box-shadow: 0 0 0 4px rgba(220, 53, 69, 0.12);
      }
      .comentario-foto-acoes {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
        padding: 16px 20px;
        background: #f8f9fa;
        flex-wrap: wrap;
      }
      .btn-comentario-secundario,
      .btn-comentario-primario {
        border: none;
        border-radius: 12px;
        padding: 12px 18px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.2s ease;
      }
      .btn-comentario-secundario {
        background: #e9ecef;
        color: var(--texto-escuro);
      }
      .btn-comentario-primario {
        background: var(--azul-corretiva);
        color: #fff;
      }
      .btn-comentario-secundario:hover,
      .btn-comentario-primario:hover {
        transform: translateY(-1px);
      }
      .btn-comentario-secundario:active,
      .btn-comentario-primario:active {
        transform: scale(0.98);
      }
      .btn-comentario-secundario:focus-visible,
      .btn-comentario-primario:focus-visible {
        outline: none;
        box-shadow: 0 0 0 4px rgba(0, 86, 179, 0.15);
      }
      .lista-rascunhos-modal {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 18px;
      }
      .item-rascunho-modal {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        text-align: left;
        padding: 14px;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: #f8fafc;
      }
      .item-rascunho-modal strong {
        display: block;
        color: #1f2937;
        font-size: 15px;
      }
      .item-rascunho-modal span {
        display: block;
        margin-top: 3px;
        font-size: 13px;
        color: #6b7280;
      }
      .btn-abrir-rascunho {
        border: none;
        background: linear-gradient(135deg, #4f8df7 0%, #2f5ec4 100%);
        color: #fff;
        font-weight: 700;
        font-size: 13px;
        padding: 10px 14px;
        border-radius: 12px;
        white-space: nowrap;
      }
      .btn-abrir-rascunho:active {
        transform: scale(0.98);
      }

      #comentarioFotoModal.show {
        display: flex;
      }
      #comentarioFotoModal .alerta-card {
        transform: scale(0.9);
        opacity: 0;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      #comentarioFotoModal.show .alerta-card {
        transform: scale(1);
        opacity: 1;
      }

      /* Modal Confirmacao */
      #intelbrasConfirmModal { 
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 12500; display: none; justify-content: center; align-items: center; padding: 20px; backdrop-filter: blur(2px);
      }
      #intelbrasConfirmModal.show { display: flex; }
      #intelbrasConfirmModal.show .alerta-card { transform: scale(1); opacity: 1; }

      /* --- MODAL FOTO FULLSCREEN (CORRIGIDO PARA TABLET E GALERIA) --- */
      .modal-fullscreen { 
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.95); z-index: 13000; 
        display: none; flex-direction: column; justify-content: center; align-items: center; 
        padding: 0; /* Remove padding que causava scroll */
      }
      .modal-fullscreen.active { display: flex; animation: fadeIn 0.2s ease; }
      
      .img-container-slider { 
        position: relative; 
        width: 100%; 
        height: 100%; /* Ocupa altura total para centralizar */
        display: flex; 
        justify-content: center; 
        align-items: center; 
      }
      
      /* Imagem Controlada */
      .img-fullscreen { 
        max-width: 90vw; 
        max-height: 80vh; 
        border-radius: 12px; 
        box-shadow: 0 0 50px rgba(0,0,0,0.8); 
        object-fit: contain;
      }
      
      /* Botão Fechar Fixo e Grande */
      .btn-close-modal { 
        position: fixed; /* Fixo na tela, não na imagem */
        top: 25px; 
        right: 25px; 
        color: white; 
        font-size: 35px; 
        cursor: pointer; 
        border: none; 
        background: rgba(0,0,0,0.6); 
        width: 50px; height: 50px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        z-index: 13001;
        transition: 0.2s;
      }
      .btn-close-modal:active { transform: scale(0.9); background: rgba(255,255,255,0.2); }
      
      /* Navegação Lateral Estilizada */
      .modal-nav { 
        position: fixed; /* Fixo nas laterais */
        top: 50%; 
        transform: translateY(-50%); 
        width: 100%; 
        display: flex; 
        justify-content: space-between; 
        padding: 0 20px; 
        pointer-events: none; /* Permite clicar através do container */
        z-index: 13001;
      }
      .btn-modal-arrow { 
        pointer-events: auto; 
        background: rgba(255,255,255,0.2); 
        border: 2px solid rgba(255,255,255,0.5);
        color: white; 
        border-radius: 50%; 
        width: 60px; height: 60px; /* Maior para tablet */
        font-size: 28px; 
        display: flex; align-items: center; justify-content: center; 
        backdrop-filter: blur(4px); 
        transition: 0.2s;
        cursor: pointer;
      }
      .btn-modal-arrow:active { background: rgba(255,255,255,0.5); transform: scale(0.95); }
      
      .modal-label { 
        position: fixed; bottom: 40px; 
        color: white; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; 
        font-size: 18px; text-shadow: 0 2px 10px rgba(0,0,0,0.8);
        background: rgba(0,0,0,0.6); padding: 8px 20px; border-radius: 50px;
      }
      .swipe-hint { 
        position: fixed; bottom: 15px;
        color: rgba(255,255,255,0.6); font-size: 12px; 
      }

      /* Toggles Estilo Acordeão Melhorado */
      .toggle-peca { 
        display: flex; align-items: center; justify-content: space-between; 
        background: #ffffff; padding: 20px; border-radius: 18px; 
        margin-bottom: 12px; cursor: pointer; 
        border: 2px solid #eef0f3; 
        box-shadow: 0 4px 10px rgba(0,0,0,0.02);
        transition: all 0.2s ease;
      }
      .toggle-peca:hover { border-color: #d0d7de; box-shadow: 0 6px 15px rgba(0,0,0,0.05); }
      
      /* Estado Ativo (Expandido) */
      .toggle-peca.active { 
        background: var(--azul-bg-suave); 
        border-color: var(--azul-corretiva); 
        color: var(--azul-corretiva);
      }
      .toggle-peca.active .toggle-text { color: var(--azul-corretiva); }
      .toggle-peca.active .icon-tgl { color: var(--azul-corretiva) !important; transform: rotate(180deg); }
      
      .toggle-text { font-weight: 700; color: var(--texto-escuro); font-size: 15px; display: flex; align-items: center; gap: 10px; }
      .icon-tgl { transition: 0.2s; font-size: 24px; color: #ccc; }
      
      .area-oculta { 
        display: none; 
        background: #ffffff; 
        padding: 25px; 
        border-radius: 0 0 18px 18px; 
        border: 2px solid var(--azul-bg-suave); 
        border-top: none;
        margin-top: -15px; margin-bottom: 20px; 
        box-shadow: 0 10px 20px rgba(0,0,0,0.03);
      }
      .area-oculta.show { display: block; animation: slideDown 0.2s ease; }

      /* --- NOVA ESTILIZAÇÃO: CARDS E BOLÕES --- */
      
      .area-card {
        background: white;
        border: 2px solid #eef0f3;
        border-radius: 24px;
        padding: 20px;
        margin-bottom: 15px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 5px 15px rgba(0,0,0,0.03);
      }
      .area-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        border-color: var(--verde-intelbras);
      }
      .area-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .area-title {
        font-weight: 700;
        color: var(--texto-escuro);
        font-size: 16px;
        display: flex; align-items: center; gap: 10px;
      }
      .area-icon {
        width: 40px; height: 40px;
        background: var(--verde-claro-bg);
        color: var(--verde-intelbras);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px;
        font-weight: bold;
      }
      
      .area-content {
        display: none; /* Começa fechado */
        margin-top: 15px;
        border-top: 1px solid #f0f0f0;
        padding-top: 15px;
      }
      .area-card.expanded .area-content {
        display: block;
        animation: slideDown 0.2s ease;
      }
      .area-card.expanded .icon-chevron {
        transform: rotate(180deg);
        color: var(--verde-intelbras);
      }

      .subarea-container {
        margin-bottom: 15px;
      }
      .subarea-title {
        font-size: 12px;
        text-transform: uppercase;
        color: #999;
        font-weight: 700;
        margin-bottom: 8px;
        letter-spacing: 1px;
      }

      .machines-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      /* BOLÃO (Machine Bubble) */
      .machine-bubble {
        background: #f8f9fa;
        color: var(--texto-escuro);
        border: 2px solid #eef0f3;
        padding: 12px 20px;
        border-radius: 50px; /* Bolão */
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.15s ease;
        text-align: center;
        flex: 1 1 auto;
        white-space: nowrap;
        max-width: 100%;
        text-overflow: ellipsis;
        overflow: hidden;
      }
      .machine-bubble:hover {
        background: var(--verde-intelbras);
        color: white;
        border-color: var(--verde-intelbras);
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(0,170,78,0.3);
      }

      .machine-bubble.status-em-dia {
        background: var(--azul-corretiva) !important;
        color: white !important;
        border-color: var(--azul-corretiva) !important;
        box-shadow: 0 4px 12px rgba(0, 86, 179, 0.3) !important;
      }
      
      .machine-bubble.status-atrasado {
        background: var(--vermelho-nok) !important;
        color: white !important;
        border-color: var(--vermelho-nok) !important;
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3) !important;
      }

      /* Animações CSS p/ Spinner de Refresh */
      @keyframes spin-anim { 100% { transform: rotate(360deg); } }
      .spin-icon { animation: spin-anim 1s linear infinite; }

      @keyframes popIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
      @keyframes slideDown { from { opacity: 0; transform: translateY(-15px); } to { opacity: 1; transform: translateY(0); } }
      .fade-in { animation: fadeIn 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
      @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
      
      .btn-voltar { 
        color: #999; font-size: 14px; font-weight: 500; 
        margin-top: 25px; display: inline-block; padding: 10px 20px; 
        border-radius: 50px; transition: 0.2s; 
        text-decoration: none; cursor: pointer;
      }
      .btn-voltar:hover { background: #f5f5f5; color: #555; }
      
      .divisor { 
        display: flex; align-items: center; text-align: center; color: #aaa; 
        margin: 25px 0; font-size: 12px; font-weight: 600; letter-spacing: 1px; 
      }
      .divisor::before, .divisor::after { content: ''; flex: 1; border-bottom: 2px solid #f0f0f0; }
      
      /* Input Date/Time Styling */
      input[type="date"], input[type="time"] { font-family: 'Poppins', sans-serif; }

      /* --- ESTILOS EXCLUSIVOS PARA O PDF (GERADO DINAMICAMENTE) --- */
      .pdf-wrapper {
        background: #fff;
        padding: 0;
        color: #333;
        width: 100%;
      }

      /* ADICIONADO PARA CORRIGIR QUEBRAS DE PÁGINA NO PDF */
      .pdf-item-container {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
        display: block;
        margin-bottom: 25px;
        padding: 15px;
        border: 1px solid #eee;
        border-radius: 10px;
        background-color: #fafafa;
      }
      
