                htmlPDF += `<div class="pdf-row"><div class="pdf-label">Peça:</div><div class="pdf-value">${d.peca}</div></div>`;
                htmlPDF += `<div class="pdf-images">`;
                if(d.fotoPecaVelha) htmlPDF += `<div class="pdf-img-box"><img src="${d.fotoPecaVelha}" class="pdf-img"><div class="pdf-img-label">VELHA</div></div>`;
                if(d.fotoPecaNova) htmlPDF += `<div class="pdf-img-box"><img src="${d.fotoPecaNova}" class="pdf-img"><div class="pdf-img-label">NOVA</div></div>`;
                htmlPDF += `</div></div>`;
            } else if(d.trocouPeca) {
                 htmlPDF += `<div class="pdf-item-container"><div class="pdf-section-title">Troca de Peças</div><div class="pdf-row"><div class="pdf-label">Peça:</div><div class="pdf-value">${d.peca}</div></div></div>`;
            }

            if (d.temFotosServico) {
                htmlPDF += `<div class="pdf-item-container"><div class="pdf-section-title">Evidências do Serviço</div>`;
                if(d.fotoServAntes || d.fotoServDepois) {
                    htmlPDF += `<div class="pdf-images">`;
                    if(d.fotoServAntes) htmlPDF += `<div class="pdf-img-box"><img src="${d.fotoServAntes}" class="pdf-img"><div class="pdf-img-label">ANTES</div></div>`;
                    if(d.fotoServDepois) htmlPDF += `<div class="pdf-img-box"><img src="${d.fotoServDepois}" class="pdf-img"><div class="pdf-img-label">DEPOIS</div></div>`;
                    htmlPDF += `</div>`;
