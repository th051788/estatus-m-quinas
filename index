      function limparIdentificadorJS(t) {
          if (!t) return "";
          let norm = t.toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
          return norm.replace(/[^A-Z0-9]/g, "").replace(/0+([0-9]+)/g, "$1");
      }

      function renderizarListaMaquinas(lista) {
          const container = document.getElementById('containerCardsMaquinas');
          container.innerHTML = "";
          
          const areas = {};
          
          lista.forEach(maq => {
              if(!areas[maq.area]) areas[maq.area] = {};
              const sub = maq.subarea || "Geral";
              if(!areas[maq.area][sub]) areas[maq.area][sub] = [];
              areas[maq.area][sub].push(maq.nome);
          });

          for (const [areaNome, subareas] of Object.entries(areas)) {
              const card = document.createElement('div');
              card.className = "area-card";
              const areaIdSafe = areaNome.replace(/[^a-zA-Z0-9]/g, '');

              const primeiraLetra = areaNome.charAt(0).toUpperCase();
              
              let htmlSubareas = "";
              for (const [subNome, maquinas] of Object.entries(subareas)) {
                  let htmlMaquinas = maquinas.map(m => {
                      let maqLimpo = limparIdentificadorJS(m);
                      let classeStatus = "";
                      
                      let ordem = ordensPendentes.find(o => o.idLimpo === maqLimpo);
                      if (ordem) {
                          if (ordem.status === "ATRASADO") classeStatus = "status-atrasado";
                          else if (ordem.status === "EM DIA") classeStatus = "status-em-dia";
                      }
                      
                      // Ajuste fino: Adicionando o this para que o spinner carregue direto no botão
                      return `<div class="machine-bubble ${classeStatus}" onclick="selecionarMaquinaManual('${m}', this)">${m}</div>`;
                  }).join('');

                  htmlSubareas += `
                      <div class="subarea-container">
                          ${subNome !== "Geral" ? `<div class="subarea-title">${subNome}</div>` : ''}
                          <div class="machines-grid">
                              ${htmlMaquinas}
                          </div>
                      </div>
                  `;
              }

              card.innerHTML = `
                  <div class="area-header" onclick="toggleCardArea('${areaIdSafe}')">
                      <div class="area-title">
                          <div class="area-icon">${primeiraLetra}</div>
                          ${areaNome}
                      </div>
                      <i class="bi bi-chevron-down icon-chevron" id="icon-${areaIdSafe}"></i>
                  </div>
                  <div class="area-content" id="content-${areaIdSafe}">
                      ${htmlSubareas}
                  </div>
              `;
              container.appendChild(card);
          }
          
          aplicarFiltrosMaquinas(); // Reaplica os filtros para manter a UI consistente
      }

