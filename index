      function calcularDowntime() {
        const start = new Date(document.getElementById('dataInicioCorr').value + ' ' + document.getElementById('horaInicioCorr').value);
        const end = new Date(document.getElementById('dataFimCorr').value + ' ' + document.getElementById('horaFimCorr').value);
        if (end < start) { document.getElementById('downtimeResult').innerHTML = "ERRO: Fim antes do início!"; document.getElementById('downtimeResult').style.color = "red"; return null; }
        
        const diffMins = Math.floor((end - start) / 60000);
        
        if (diffMins === 0) {
           document.getElementById('downtimeResult').innerHTML = "Tempo de Parada: 0 min (Ajuste o horário)";
           document.getElementById('downtimeResult').style.color = "red";
           return null;
        }

        let txt = Math.floor(diffMins/60) > 0 ? `${Math.floor(diffMins/60)}h ${diffMins%60}min` : `${diffMins} min`;
        document.getElementById('downtimeResult').innerHTML = `Tempo de Parada: ${txt}`; document.getElementById('downtimeResult').style.color = "#e65100";
        return txt;
      }

