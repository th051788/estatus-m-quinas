                if (maquinasCache && maquinasCache.length > 0) {
                    renderizarListaMaquinas(maquinasCache);
                } else {
                    // Prevenção extrema: cache vazio e não estava buscando, força busca
                    buscarDadosDoServidor();
                    setTimeout(tentarRenderizar, 500);
                }
