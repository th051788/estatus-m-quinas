                if(itm.obs) htmlPDF += `<div style="font-size:11px; color:#c0392b; margin-top:5px;">Obs: ${itm.obs}</div>`;
                
                if(itm.photoDepois) {
                    htmlPDF += `<div class="pdf-images">`;
                    if(itm.photoAntes) htmlPDF += `<div class="pdf-img-box"><img src="${itm.photoAntes}" class="pdf-img"><div class="pdf-img-label">ANTES</div></div>`;
                    htmlPDF += `<div class="pdf-img-box"><img src="${itm.photoDepois}" class="pdf-img"><div class="pdf-img-label">DEPOIS</div></div>`;
                    htmlPDF += `</div>`;
                }
                
                // FOTOS EXTRAS POR ITEM NO PDF
