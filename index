      function montarRascunhoPreventivaAtual() {
          return {
              items: checklistItems,
              answers: checklistAnswers,
              step: currentStep,
              type: checklistType,
              equipe: equipeAuxiliarPrev,
              startTime: checklistStartTime ? checklistStartTime.getTime() : new Date().getTime(),
              ordemID: ordemAtuParaSalvar
          };
      }

      function temRascunhoPreventivaValido(r) {
          if (!r || typeof r !== 'object') return false;

          const itens = Array.isArray(r.items) ? r.items : [];
          const respostas = Array.isArray(r.answers) ? r.answers : [];
          const equipe = Array.isArray(r.equipe) ? r.equipe : [];

          if (!itens.length || !respostas.length) return false;
          if (itens.length !== respostas.length) return false;

          const temEquipe = equipe.length > 0;
          const temOrdem = String(r.ordemID || '').trim() !== '';
          const temRespostasPreenchidas = respostas.some(resp => {
              if (!resp || typeof resp !== 'object') return false;

              const temStatus = resp.status !== null && resp.status !== undefined && String(resp.status).trim() !== '' && resp.status !== 'OBS';
              const temObs = String(resp.obs || '').trim() !== '';
              const temFotoAntes = String(resp.photoAntes || '').trim() !== '';
              const temFotoDepois = String(resp.photoDepois || '').trim() !== '';
              const temExtras = Array.isArray(resp.extras) && resp.extras.length > 0;

              return temStatus || temObs || temFotoAntes || temFotoDepois || temExtras;
          });

          return temEquipe || temOrdem || temRespostasPreenchidas;
      }

