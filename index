            if (d.temFotosServico) {
                if (d.fotoServDepois) cont.innerHTML += `<div class="p-2 border rounded mb-2 bg-light"><strong>Serviço Executado:</strong><br><img src="${d.fotoServDepois}" class="img-detail" onclick="abrirFotoGrande('${d.fotoServAntes||""}', '${d.fotoServDepois}')"></div>`;
                if (d.fotosExtras && d.fotosExtras.length > 0) {
                    let extH = '<div class="extra-photos-grid">';
                    d.fotosExtras.forEach((ex, idx) => {
                        const urlExtra = typeof ex === 'string' ? ex : ex.imagem;
                        const comentarioExtra = ex && typeof ex === 'object' && ex.comentario ? `<div class="extra-photo-caption">${String(ex.comentario).replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>` : '';
                        extH += `<div><img src="${urlExtra}" class="img-extra-thumb" onclick="abrirGaleriaExtras(${index}, ${idx})">${comentarioExtra}</div>`;
                    });
                    cont.innerHTML += extH + '</div>';
                }
            }
          }
          toggleTelas('telaDashboardCorretiva', 'telaVisualizarPreventiva');
        } catch (e) { exibirMensagem("Erro", "Erro ao carregar detalhes.", "error"); }
      }

      function handleImageCapture(event, tipo) {
        const file = event.target.files[0]; if (!file) return;
        const reader = new FileReader(); reader.onload = (e) => {
          compressImage(e.target.result).then(compressed => {
            if(tipo === 'Antes') checklistAnswers[currentStep].photoAntes = compressed; else checklistAnswers[currentStep].photoDepois = compressed;
            renderStep();
            salvarRascunhoPreventiva(); // Salva rascunho de preventiva
          });
        }; reader.readAsDataURL(file);
        event.target.value = ""; // MEMORY FIX
      }
      function removeCapturedPhoto(tipo) { 
          if(tipo === 'Antes') checklistAnswers[currentStep].photoAntes = ""; else checklistAnswers[currentStep].photoDepois = ""; 
          renderStep(); 
          salvarRascunhoPreventiva(); // Salva rascunho
      }
      
      // NOVAS FUNÇÕES PARA FOTOS EXTRAS DA PREVENTIVA POR ITEM
      function addFotoExtraPrev(event) {
        const file = event.target.files[0]; if (!file) return;
        const reader = new FileReader(); reader.onload = (e) => {
          compressImage(e.target.result).then(compressed => {
            if(!checklistAnswers[currentStep].extras) checklistAnswers[currentStep].extras = [];
            checklistAnswers[currentStep].extras.push(compressed);
            renderGaleriaExtrasPrev();
            salvarRascunhoPreventiva();
          });
        }; reader.readAsDataURL(file);
        event.target.value = ""; // MEMORY FIX
      }
      
      function removeFotoExtraPrev(index) {
        checklistAnswers[currentStep].extras.splice(index, 1);
        renderGaleriaExtrasPrev();
        salvarRascunhoPreventiva();
      }
      
      function renderGaleriaExtrasPrev() {
        const gal = document.getElementById('galeriaExtrasPrev');
        if(!gal) return;
        gal.innerHTML = "";
        const extras = checklistAnswers[currentStep]?.extras || [];
        extras.forEach((src, idx) => {
            gal.innerHTML += `<div class="extra-photo-container"><img src="${src}" class="img-extra-thumb" onclick="abrirGaleriaExtrasPrevVisualizacao(${idx})"><button class="btn-remove-extra" onclick="removeFotoExtraPrev(${idx})">&times;</button></div>`;
        });
      }

      function validarAntesPreventiva() {
        const btn = document.getElementById('btnValidarPrev');
        const spinner = document.getElementById('spinBtnValPrev');
        btn.disabled = true; 
        spinner.classList.remove('hidden');

        google.script.run
        .withFailureHandler((erro) => {
            btn.disabled = false; 
            spinner.classList.add('hidden');
            exibirMensagem("Erro de Sistema", erro.message, "error");
        })
        .withSuccessHandler((resultado) => {
          btn.disabled = false; 
          spinner.classList.add('hidden');
          
          if(resultado && resultado.erro) {
             exibirMensagem("Erro na Planilha", resultado.erro, "error");
             return;
          }

          document.getElementById('badgeOrdem').innerText = maqAtu;
          const infoDiv = document.getElementById('infoOrdem');
          const btnProsseguir = document.getElementById('btnProsseguirChecklist');
          btnProsseguir.classList.add('hidden');
          
          // Popular Select de Equipe Auxiliar baseado na área do Técnico logado
          const selectTec = document.getElementById('tecnico');
          const selectedOption = selectTec.options[selectTec.selectedIndex];
          const optgroup = selectedOption ? selectedOption.parentElement : null;
          const selectAux = document.getElementById('selectAuxiliarPrev');
          selectAux.innerHTML = '<option value="" selected disabled>Adicionar técnico...</option>';
          if (optgroup && optgroup.tagName === 'OPTGROUP') {
              Array.from(optgroup.children).forEach(opt => {
                  if (opt.value !== tecAtu) { // Não adiciona ele mesmo
                      const newOpt = document.createElement('option');
                      newOpt.value = opt.value;
                      newOpt.text = opt.text;
                      selectAux.appendChild(newOpt);
                  }
              });
          }
          equipeAuxiliarPrev = [];
          renderEquipePrev();

          if (resultado.encontrou) {
            ordemAtuParaSalvar = resultado.ordem; // Guarda a ordem para o LOG
            infoDiv.innerHTML = `<div class="alert alert-info"><strong>Ordem:</strong> ${resultado.ordem}<br><strong>Status:</strong> ${resultado.status}</div>`;
            if (resultado.status && resultado.status.includes("CONCLUÍDO")) {
              infoDiv.innerHTML += `<div class="alert alert-danger mt-2">Ordem já concluída.</div>`;
              document.getElementById('divEquipePrev').classList.add('hidden');
            } else {
              document.getElementById('divEquipePrev').classList.remove('hidden');
              btnProsseguir.classList.remove('hidden');
            }
          } else {
            infoDiv.innerHTML = `<div class="alert alert-warning">Não há ordens preventivas abertas para este equipamento.</div>`;
            document.getElementById('divEquipePrev').classList.add('hidden');
            btnProsseguir.classList.add('hidden');
          }
          toggleTelas('telaOpcoes', 'telaValidacaoOrdem');
        })
        .verificarOrdemPreventiva(maqAtu, tecAtu);
      }
      
      function iniciarWizardPreventiva() {
        autoSavePreventivaHabilitado = false;
        document.getElementById('badgePrev').innerText = maqAtu; 

        // VERIFICA RASCUNHO MANUAL NA PREVENTIVA
        const chaveRascunho = obterChaveRascunhoPreventiva();
        const rascunhoStr = chaveRascunho ? localStorage.getItem(chaveRascunho) : null;
        if (rascunhoStr) {
             try {
                 const rascunho = JSON.parse(rascunhoStr);
                 if (temRascunhoPreventivaValido(rascunho)) {
                     exibirConfirmacao("Rascunho Localizado", "Você tem um checklist de preventiva em andamento. Deseja continuar de onde parou?", () => {
                         restaurarPreventivaDireto(rascunho);
                     }, () => {
                         localStorage.removeItem(chaveRascunho);
                         iniciarPreventivaNova();
                     });
                     return;
                 }
             } catch(e) {
             }

             localStorage.removeItem(chaveRascunho);
        }

        iniciarPreventivaNova();
      }

      function iniciarPreventivaNova() {
        autoSavePreventivaHabilitado = true;
        checklistStartTime = new Date();
        
        toggleTelas('telaValidacaoOrdem', 'telaPreventiva');
        document.getElementById('wizardContent').classList.add('hidden'); 
        document.getElementById('wizardLoading').classList.remove('hidden');
        
        google.script.run.withSuccessHandler((dados) => {
          checklistItems = dados.itens; checklistType = dados.tipo;
          if (!checklistItems || !checklistItems.length) { exibirMensagem("Aviso", "Sem checklist cadastrado.", "info"); toggleTelas('telaPreventiva', 'telaOpcoes'); return; }
          
          checklistAnswers = checklistItems.map(item => {
              // Suporta tanto o antigo array de strings quanto o novo array de objetos
              let texto = typeof item === 'string' ? item : item.pergunta;
              let tipoGatilho = typeof item === 'string' ? '' : (item.tipoGatilho || '');
              let linkImagem = typeof item === 'string' ? '' : (item.linkImagem || '');

              return {
                  item: texto,
                  tipo: tipoGatilho,
                  img: linkImagem,
                  status: tipoGatilho === 'OBS' ? 'OBS' : null,
                  obs: "",
                  photoAntes: "",
                  photoDepois: "",
                  extras: []
              };
          });

          currentStep = 0; 
          
          document.getElementById('wizardLoading').classList.add('hidden'); 
          document.getElementById('wizardContent').classList.remove('hidden');
          renderStep();
        }).buscarItensChecklist(maqAtu, tecAtu);
      }
      
      function renderStep() {
        const res = checklistAnswers[currentStep];
        document.getElementById('stepCounter').innerText = `ITEM ${currentStep + 1} DE ${checklistItems.length}`; 
        document.getElementById('stepQuestion').innerText = res.item;
        document.getElementById('obsInput').value = res.obs || "";
        
        // FUNÇÃO PARA CONVERTER LINK DO DRIVE EM IMAGEM DIRETA
        const formatarLinkDrive = (url) => {
            if (!url) return "";
            
            // Busca o ID da imagem em diferentes formatos de link do Drive
            let match = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
            if (!match) match = url.match(/id=([a-zA-Z0-9_-]+)/);
            if (!match) match = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
            
            if (match && match[1]) {
                // O domínio lh3.googleusercontent.com ignora o bloqueio de cookies do Drive 
                // e exibe a foto publicamente sem redirecionamentos.
                return `https://lh3.googleusercontent.com/d/${match[1]}`;
            }
            return url;
        };

        // Renderiza a imagem de instrução (se houver)
        const instrucaoImg = document.getElementById('instrucaoImg');
        if (res.img) {
            instrucaoImg.src = formatarLinkDrive(res.img);
            instrucaoImg.classList.remove('hidden');
        } else {
            instrucaoImg.classList.add('hidden');
            instrucaoImg.src = "";
        }

        const grupoBotoes = document.getElementById('grupoBotoesStatus');
        const containerExtras = document.getElementById('extrasContainer');

        ['btnOK', 'btnNOK', 'btnNA'].forEach(id => document.getElementById(id).className = 'btn-status');
        
        if (res.tipo === 'OBS') {
            grupoBotoes.classList.add('hidden');
            containerExtras.classList.remove('show'); // Oculta comentários e fotos para o tipo OBS
            if (!res.status) res.status = 'OBS'; // Garante que passe no validador
        } else {
            grupoBotoes.classList.remove('hidden');
            if (res.status === 'OK' || res.status === 'NOK') {
                containerExtras.classList.add('show');
                document.getElementById('btn' + res.status).classList.add(`selected-${res.status.toLowerCase()}`);
            } else {
                containerExtras.classList.remove('show');
                if(res.status === 'NA') document.getElementById('btnNA').classList.add('selected-na');
            }
        }

        renderFotoItem('Antes', res.photoAntes);
        renderFotoItem('Depois', res.photoDepois);
        renderGaleriaExtrasPrev(); // Renderiza galeria extra do item atual

        document.getElementById('btnNext').innerHTML = (currentStep === checklistItems.length - 1) ? 'Finalizar <i class="bi bi-check-lg"></i>' : 'Próximo <i class="bi bi-arrow-right"></i>';
        document.getElementById('btnPrev').disabled = (currentStep === 0);
      }

      function renderFotoItem(tipo, base64) {
        const img = document.getElementById('prevImg' + tipo);
        const btn = document.getElementById('btnCam' + tipo);
        const remove = document.getElementById('remove' + tipo);

        if (base64) {
            img.src = base64;
            img.classList.add('active');
            btn.style.display = 'none'; 
            remove.classList.add('active'); 
        } else {
            img.classList.remove('active');
            btn.style.display = 'flex'; 
            remove.classList.remove('active'); 
        }
      }
      
      function setStatus(s) { 
          checklistAnswers[currentStep].status = s; 
          renderStep(); 
          salvarRascunhoPreventiva(); 
      }
      
      function salvarObs() { 
          checklistAnswers[currentStep].obs = document.getElementById('obsInput').value; 
          salvarRascunhoPreventiva(); 
      }
      
      function nextStep() {
        checklistAnswers[currentStep].obs = document.getElementById('obsInput').value;
        if (!checklistAnswers[currentStep].status) { exibirMensagem("Atenção", "Selecione um status antes de prosseguir.", "info"); return; }
        if (currentStep < checklistItems.length - 1) { 
            currentStep++; 
            renderStep(); 
            salvarRascunhoPreventiva();
        } else { 
            finalizarWizard(); 
        }
      }
      function prevStep() { 
          checklistAnswers[currentStep].obs = document.getElementById('obsInput').value; 
          if (currentStep > 0) { 
              currentStep--; 
              renderStep(); 
              salvarRascunhoPreventiva();
          } 
      }
      function finalizarWizard() {
        checklistAnswers[currentStep].obs = document.getElementById('obsInput').value;
        
        const endTime = new Date();
        const diff = endTime - checklistStartTime;
        const tempoTotalMinSec = `${Math.floor(diff/60000)} min ${Math.floor((diff%60000)/1000)}s`;
        
        const pad = n => String(n).padStart(2, '0');
        const formatDateTime = (d) => `${pad(d.getDate())}/${pad(d.getMonth()+1)}/${d.getFullYear()} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
        
        // Passa a string formatada para o backend (que vai direto pro email e pro JSON sem quebrar nada)
        const tempoFormatado = `${tempoTotalMinSec} (Início: ${formatDateTime(checklistStartTime)} - Fim: ${formatDateTime(endTime)})`;
        const equipeFinal = [tecAtu, ...equipeAuxiliarPrev].join(", ");

        document.getElementById('wizardContent').classList.add('hidden'); document.getElementById('wizardLoading').classList.remove('hidden');
        google.script.run.withSuccessHandler((msg) => { 
            exibirMensagem("Concluído", msg); 
            autoSavePreventivaHabilitado = false;
            removerRascunhoPreventivaAtual();
            
            // LIMPEZA DA MEMORIA APOS SUCESSO DO UPLOAD
            checklistAnswers = []; 
            checklistItems = [];
            
            toggleTelas('telaPreventiva', 'telaOpcoes'); 
        }).salvarChecklistPreventiva(equipeFinal, maqAtu, checklistType, checklistAnswers, tempoFormatado, ordemAtuParaSalvar, []);
      }

      function confirmarCancelamentoPreventiva() {
        exibirConfirmacao(
            "Cancelar Checklist", 
            "Sair cancelará o checklist em andamento. Deseja continuar?", 
            () => {
                // Clicou SIM, quero cancelar e descartar
                autoSavePreventivaHabilitado = false;
                removerRascunhoPreventivaAtual();
                toggleTelas('telaPreventiva', 'telaOpcoes');
            }
        );
      }

      function confirmarCancelamentoCorretiva() {
        exibirConfirmacao(
            "Cancelar Corretiva",
            "Ao cancelar, o rascunho desta corretiva será removido. Deseja continuar?",
            () => {
                autoSaveCorretivaHabilitado = false;
                removerRascunhoCorretivaAtual();
                fotosCorretiva = { pecaVelha: "", pecaNova: "", servAntes: "", servDepois: "", extras: [] };
                toggleTelas('telaRegistroCorretiva', 'telaOpcoes');
            }
        );
      }

      function persistirRascunhoCorretivaAoSair() {
        if (!autoSaveCorretivaHabilitado) return;
        if (document.getElementById('telaRegistroCorretiva').classList.contains('hidden')) return;
        salvarRascunhoCorretiva(true);
      }

      function persistirRascunhoPreventivaAoSair() {
        if (!autoSavePreventivaHabilitado) return;
        if (document.getElementById('telaPreventiva').classList.contains('hidden')) return;
        salvarRascunhoPreventiva(true);
      }

      window.addEventListener('beforeunload', () => {
        persistirRascunhoCorretivaAoSair();
        persistirRascunhoPreventivaAoSair();
      });
      window.addEventListener('pagehide', () => {
        persistirRascunhoCorretivaAoSair();
        persistirRascunhoPreventivaAoSair();
      });
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') {
            persistirRascunhoCorretivaAoSair();
            persistirRascunhoPreventivaAoSair();
        }
      });

      function toggleTelas(s, e) {
        openFullscreen(); 
        document.getElementById('cardPrincipal').style.opacity = '0'; 
        setTimeout(() => { 
            document.querySelectorAll('#cardPrincipal > div[id^="tela"]').forEach(tela => tela.classList.add('hidden'));
            document.getElementById(e).classList.remove('hidden'); 
            document.getElementById('cardPrincipal').style.opacity = '1'; 
        }, 150); // Reduzido para navegação mais rápida
      }
      function fecharModalManual(e) { if(e.target.id === "modalFotoGrande" || e.target.className === "btn-close-modal") fecharFotoGrande(); }
      
      // FUNÇÃO PARA VOLTAR E SEMPRE PARAR A CÂMERA
      function voltarParaSelecao() { 
        openFullscreen(); 
        pararCamera().then(() => {
           toggleTelas('telaQRCode', 'telaSelecao');
        });
      }
      
      function voltarParaQRCode() { 
        openFullscreen(); 
        toggleTelas('telaOpcoes', 'telaQRCode'); 
        // Resetar status da leitura e reativar botões
        document.getElementById('qrStatus').innerText = "";
        document.getElementById('processingQR').classList.add('hidden');
        document.getElementById('btnCapturarQR').disabled = false;
        document.getElementById('btnListaManualQR').disabled = false;
        carregarMaquinas(); 
      }
      
      function filtrarTabela() {
        const val = document.getElementById("buscaHist").value.toUpperCase(), trs = document.getElementById("listaHist").getElementsByTagName("tr");
        for (let i = 0; i < trs.length; i++) { trs[i].style.display = trs[i].textContent.toUpperCase().includes(val) ? "" : "none"; }
      }

      document.querySelectorAll('button, .btn-voltar, .btn-main').forEach(elem => {
          elem.addEventListener('click', function() {
              openFullscreen();
          });
      });

    </script>
  </body>
</html>
