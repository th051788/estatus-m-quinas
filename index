      async function processarImagemQR(event) {
        const file = event.target.files[0];
        if (!file) return;

        const statusDiv = document.getElementById('qrStatus');
        const processingDiv = document.getElementById('processingQR');
        const processingText = document.getElementById('processingQRText');
        const btnCapturar = document.getElementById('btnCapturarQR');
        const btnManual = document.getElementById('btnListaManualQR');
        
        statusDiv.innerText = "";
        processingDiv.classList.remove('hidden');
        processingText.innerText = "Processando imagem...";

        try {
          // Bloqueia botões para evitar cliques múltiplos
          btnCapturar.disabled = true;
          btnManual.disabled = true;

          // Lê o arquivo original apenas uma vez como DataURL para economizar memória RAM
          let base64Original = await new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = (e) => resolve(e.target.result);
            reader.onerror = (e) => reject(e);
            reader.readAsDataURL(file);
          });

          const scannerFile = new Html5Qrcode("reader-temp");

          // ETAPA 1: TENTATIVA OTIMIZADA (800px)
          processingText.innerText = "Analise rápida (Passo 1/3)...";
          let base64Pass1 = await compressImage(base64Original, 800, 800);
          let blobPass1 = await (await fetch(base64Pass1)).blob();
          let filePass1 = new File([blobPass1], "s1.jpg", { type: "image/jpeg" });
          base64Pass1 = null; // Liberar memoria

          try {
            const decodedText = await scannerFile.scanFile(filePass1, true);
            base64Original = null; // Liberar original grande
            tratarSucessoLeituraQR(decodedText);
            return;
          } catch (e1) {
            console.warn("Passo 1 falhou, tentando refinamento...");
          }

          // ETAPA 2: TRATAMENTO DE ILUMINAÇÃO (Grayscale + Contraste)
          processingText.innerText = "Ajustando contraste (Passo 2/3)...";
          let base64Pass2 = await applyImageFilters(base64Original, 'grayscale(100%) contrast(220%) brightness(110%)', 1000);
          let blobPass2 = await (await fetch(base64Pass2)).blob();
          let filePass2 = new File([blobPass2], "s2.jpg", { type: "image/jpeg" });
          base64Pass2 = null;

          try {
            const decodedText = await scannerFile.scanFile(filePass2, true);
            base64Original = null;
            tratarSucessoLeituraQR(decodedText);
            return;
          } catch (e2) {
            console.warn("Passo 2 falhou, tentando alta resolução...");
          }

          // ETAPA 3: ALTA DEFINIÇÃO (1400px)
          processingText.innerText = "Análise profunda (Passo 3/3)...";
          let base64Pass3 = await compressImage(base64Original, 1400, 1400);
          base64Original = null; // Finalmente limpa a original
          let blobPass3 = await (await fetch(base64Pass3)).blob();
          let filePass3 = new File([blobPass3], "s3.jpg", { type: "image/jpeg" });
          base64Pass3 = null;

          try {
            const decodedText = await scannerFile.scanFile(filePass3, true);
            tratarSucessoLeituraQR(decodedText);
          } catch (e3) {
            throw new Error("QR Code não identificado");
          }

        } catch (err) {
          // Reativa botões em caso de erro final
          btnCapturar.disabled = false;
          btnManual.disabled = false;
          processingDiv.classList.add('hidden');
          statusDiv.innerHTML = "<span class='text-danger'>NÃO RECONHECIDO</span><br><small class='text-muted'>Mantenha o foco e tente novamente.</small>";
          console.error("Erro no processamento do QR:", err);
        } finally {
          event.target.value = ""; // LIMPEZA FUNDAMENTAL: SOLTA ARQUIVO DA MEMORIA
        }
      }

      function tratarSucessoLeituraQR(text) {
          const statusDiv = document.getElementById('qrStatus');
          const processingText = document.getElementById('processingQRText');
          
          statusDiv.innerText = "EQUIPAMENTO IDENTIFICADO!";
          processingText.innerText = "Acessando página do equipamento...";
          maqAtu = text;
          
          google.script.run
            .withSuccessHandler((resultado) => {
               document.getElementById('btnCapturarQR').disabled = false;
               document.getElementById('btnListaManualQR').disabled = false;
               irParaOpcoes(resultado);
            })
            .withFailureHandler((err) => {
               document.getElementById('btnCapturarQR').disabled = false;
               document.getElementById('btnListaManualQR').disabled = false;
               document.getElementById('processingQR').classList.add('hidden');
               document.getElementById('qrStatus').innerHTML = "<span class='text-danger'>ERRO DE CONEXÃO</span>";
            })
            .processarLeituraQRCode(tecAtu, maqAtu);
      }

      function applyImageFilters(base64, filterStr, size) {
          return new Promise((resolve) => {
              const img = new Image();
              img.src = base64;
              img.onload = () => {
                  const canvas = document.createElement('canvas');
                  const ctx = canvas.getContext('2d');
                  let width = img.width, height = img.height;
                  if (width > height) { if (width > size) { height *= size / width; width = size; } } 
                  else { if (height > size) { width *= size / height; height = size; } }
                  
                  canvas.width = width;
                  canvas.height = height;
                  ctx.filter = filterStr; // Grayscale e Contraste ajudam o leitor QR
                  ctx.drawImage(img, 0, 0, width, height);
                  resolve(canvas.toDataURL('image/jpeg', 0.9));
                  img.src = ""; // Liberar memoria
              };
          });
      }

