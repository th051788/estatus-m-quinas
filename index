      function listarRascunhosPendentesDoTecnico() {
          const rascunhos = [];

          for (let i = 0; i < localStorage.length; i++) {
              const key = localStorage.key(i);
              if (!key) continue;

              if (key.startsWith(`rascunho_corr_${tecAtu}_`)) {
                  try {
                      const candidato = JSON.parse(localStorage.getItem(key));
                      if (temRascunhoCorretivaValido(candidato)) {
                          rascunhos.push({
                              tipo: 'corretiva',
                              tipoTexto: 'Manutenção Corretiva',
                              maquina: key.replace(`rascunho_corr_${tecAtu}_`, ''),
                              chave: key,
                              dados: candidato
                          });
                      } else {
                          localStorage.removeItem(key);
                      }
                  } catch(e) {
                      localStorage.removeItem(key);
                  }
              } else if (key.startsWith(`rascunho_prev_${tecAtu}_`)) {
                  try {
                      const candidato = JSON.parse(localStorage.getItem(key));
                      if (temRascunhoPreventivaValido(candidato)) {
                          rascunhos.push({
                              tipo: 'preventiva',
                              tipoTexto: 'Preventiva',
                              maquina: key.replace(`rascunho_prev_${tecAtu}_`, ''),
                              chave: key,
                              dados: candidato
                          });
                      } else {
                          localStorage.removeItem(key);
                      }
                  } catch(e) {
                      localStorage.removeItem(key);
                  }
              }
          }

          return rascunhos.sort((a, b) => a.maquina.localeCompare(b.maquina, 'pt-BR'));
      }

