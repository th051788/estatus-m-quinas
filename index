      function buscarDadosDoServidor() {
          // Busca Ordens primeiro, pois as bolinhas dependem disso
          isFetchingOrdens = true;
          google.script.run
            .withSuccessHandler((ordens) => {
                ordensPendentes = ordens || [];
                try { localStorage.setItem(`intelbras_ordensCache_${tecAtu}`, JSON.stringify(ordensPendentes)); } catch(e) {}
                isFetchingOrdens = false;
                
                // Sempre re-renderiza quando as ordens chegam para atualizar as cores das bolinhas na hora!
                if (maquinasCache.length > 0 && !isFetchingMaquinas && !document.getElementById('telaListaMaquinas').classList.contains('hidden')) {
                    renderizarListaMaquinas(maquinasCache);
                }
            })
            .withFailureHandler(() => { isFetchingOrdens = false; })
            .buscarOrdensPendentes(tecAtu);

          // Depois atualiza as máquinas se necessário
          if (maquinasCache.length === 0 && !isFetchingMaquinas) {
              isFetchingMaquinas = true;
              google.script.run
                .withSuccessHandler((maquinas) => {
                    maquinasCache = maquinas || [];
                    try { localStorage.setItem('intelbras_maquinasCache', JSON.stringify(maquinasCache)); } catch(e) {}
                    isFetchingMaquinas = false;
                    
                    if (!isFetchingOrdens && !document.getElementById('telaListaMaquinas').classList.contains('hidden')) {
                        renderizarListaMaquinas(maquinasCache);
                    }
                })
                .withFailureHandler(() => { isFetchingMaquinas = false; })
                .listarMaquinas();
          }
      }

      function forcarAtualizacaoMaquinas(btn) {
          if (!btn) return;
          const icon = btn.querySelector('i');
          icon.classList.add('spin-icon');
          btn.disabled = true;

          document.getElementById('containerCardsMaquinas').innerHTML = '<div class="text-center py-5"><div class="spinner-border text-success" role="status"></div><p class="mt-2 text-muted small">Sincronizando catálogo de máquinas...</p></div>';

          maquinasCache = [];
          ordensPendentes = [];
          localStorage.removeItem('intelbras_maquinasCache');
          if(tecAtu) localStorage.removeItem(`intelbras_ordensCache_${tecAtu}`);

          isFetchingMaquinas = true;
          isFetchingOrdens = true;

          google.script.run
            .withSuccessHandler((res) => {
                if (!res || res.sucesso !== true) {
                    throw new Error((res && res.erro) || 'Falha ao sincronizar catálogo');
                }

                isFetchingMaquinas = false;
                isFetchingOrdens = false;
                buscarDadosDoServidor();

                const checkFinish = setInterval(() => {
                    if(!isFetchingMaquinas && !isFetchingOrdens) {
                        clearInterval(checkFinish);
                        icon.classList.remove('spin-icon');
                        btn.disabled = false;
                        renderizarListaMaquinas(maquinasCache);
                    }
                }, 300);
            })
            .withFailureHandler((err) => {
                isFetchingMaquinas = false;
                isFetchingOrdens = false;
