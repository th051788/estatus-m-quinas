      function temRascunhoCorretivaValido(r) {
        if (!r || typeof r !== 'object') return false;

        const temTexto = [r.defeito, r.causa, r.acao, r.descPeca].some(v => String(v || '').trim() !== '');
        const temEquipe = Array.isArray(r.equipe) && r.equipe.some(nome => String(nome || '').trim() !== '');
        const fotos = r.fotos || {};
        const extrasNormalizadas = normalizarFotosExtrasCorretiva(fotos.extras);
        const temFotos = [fotos.pecaVelha, fotos.pecaNova, fotos.servAntes, fotos.servDepois]
          .some(foto => String(foto || '').trim() !== '') || extrasNormalizadas.length > 0;
        const temEmailMarcado = r.enviarEmail === true;

        // IMPORTANTE: data/hora padrão e áreas abertas/fechadas não devem, sozinhas,
        // gerar rascunho. Só consideramos rascunho quando houver conteúdo realmente
        // alterado pelo usuário.
        return temTexto || temEquipe || temFotos || temEmailMarcado;
      }

      function irParaRegistroCorretiva() {
        autoSaveCorretivaHabilitado = false;
        document.getElementById('maqCorretivaNome').innerText = maqAtu;
        const agora = new Date();
        const yyyy = agora.getFullYear(), mm = String(agora.getMonth() + 1).padStart(2, '0'), dd = String(agora.getDate()).padStart(2, '0'), hh = String(agora.getHours()).padStart(2, '0'), min = String(agora.getMinutes()).padStart(2, '0');
        
        // ZERA TUDO INICIALMENTE SE NÃO HOUVER RESTAURAÇÃO
        document.getElementById('dataInicioCorr').value = `${yyyy}-${mm}-${dd}`;
        document.getElementById('horaInicioCorr').value = `${hh}:${min}`;
        document.getElementById('dataFimCorr').value = `${yyyy}-${mm}-${dd}`;
        document.getElementById('horaFimCorr').value = `${hh}:${min}`;
        document.getElementById('defeitoCorr').value = ""; 
        document.getElementById('causaCorr').value = ""; 
        document.getElementById('acaoCorr').value = ""; 
        document.getElementById('descPeca').value = "";
        equipeAuxiliar = []; 
        statusAreas = { areaPecas: false, areaFotosServico: false };
        fotosCorretiva = { pecaVelha: "", pecaNova: "", servAntes: "", servDepois: "", extras: [] };
        enviarEmailCorretivaSelecionado = false;
        limparSelecaoEmailCorretiva();
        
        document.getElementById('areaPecas').classList.remove('show'); document.getElementById('togglePecaBtn').classList.remove('active');
        document.getElementById('areaFotosServico').classList.remove('show'); document.getElementById('toggleServicoBtn').classList.remove('active');
        document.querySelectorAll('.icon-tgl').forEach(i => { i.className = "bi bi-chevron-down icon-tgl"; i.style.color = "#ccc"; });

        // VERIFICA SE TEM RASCUNHO PARA ESTA MÁQUINA SE FOI CLICADA MANUALMENTE
        const rascunhoStr = localStorage.getItem(`rascunho_corr_${tecAtu}_${maqAtu}`);
        
        if (rascunhoStr) {
            try {
                const r = JSON.parse(rascunhoStr);
                if (temRascunhoCorretivaValido(r)) {
                    exibirConfirmacao("Rascunho Localizado", "Encontrámos um registo que não foi guardado. Deseja restaurar as informações e fotos de onde parou?", () => {
                        autoSaveCorretivaHabilitado = true;
                        restaurarCorretivaDireto(r);
                    }, () => {
                        // Clicou NÃO (Limpar Rascunho)
                        localStorage.removeItem(`rascunho_corr_${tecAtu}_${maqAtu}`);
                        autoSaveCorretivaHabilitado = true;
                        limparSelecaoEmailCorretiva();
                        calcularDowntime(); renderFotosCorretiva(); renderGaleriaExtras(); renderEquipe();
                        carregarSugestoesEExibirCorretiva();
                    });
                    return; // Evita executar o resto antes de responder
                } else {
                    localStorage.removeItem(`rascunho_corr_${tecAtu}_${maqAtu}`);
                }
            } catch(e) {
                localStorage.removeItem(`rascunho_corr_${tecAtu}_${maqAtu}`);
            }
        } 
        
        // Fluxo Normal (Se não tem rascunho)
        autoSaveCorretivaHabilitado = true;
        limparSelecaoEmailCorretiva();
        calcularDowntime(); renderFotosCorretiva(); renderGaleriaExtras(); renderEquipe();
        carregarSugestoesEExibirCorretiva();
      }

