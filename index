            if (d.extrasGlobais && d.extrasGlobais.length > 0) {
                htmlPDF += `<div class="pdf-item-container">`;
                htmlPDF += `<div style="font-weight:bold; font-size:12px; color:#555; margin-bottom:10px;">Fotos Extras do Serviço:</div><div class="pdf-images">`;
