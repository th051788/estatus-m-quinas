      // NOVO: Função Global de Filtro (Cruza Texto + Status da Legenda)
      function aplicarFiltrosMaquinas() {
          const cards = document.querySelectorAll('.area-card');
          
          cards.forEach(card => {
              let encontrouNoCard = false;
              const bubblesInCard = card.querySelectorAll('.machine-bubble');
              
              bubblesInCard.forEach(bubble => {
                  const txt = bubble.innerText.toLowerCase();
                  
                  // Analisando classes CSS que definem o status da máquina
                  const hasEmDia = bubble.classList.contains('status-em-dia');
                  const hasAtrasado = bubble.classList.contains('status-atrasado');
                  const hasSemOrdem = !hasEmDia && !hasAtrasado;

                  // 1. Passou no filtro de texto? (Verdadeiro se estiver vazio ou contiver o texto)
                  let textMatch = !filtroTextoAtivo || txt.includes(filtroTextoAtivo);
                  
                  // 2. Passou no filtro de status (botões clicáveis)?
                  let statusMatch = true;
                  if (filtroStatusAtivo === 'status-em-dia' && !hasEmDia) statusMatch = false;
                  if (filtroStatusAtivo === 'status-atrasado' && !hasAtrasado) statusMatch = false;
                  if (filtroStatusAtivo === 'sem-ordem' && !hasSemOrdem) statusMatch = false;

                  // Se passou nas duas validações, a bolinha aparece
                  if (textMatch && statusMatch) {
                      bubble.style.display = "block";
                      encontrouNoCard = true;
                  } else {
                      bubble.style.display = "none";
                  }
              });

              // Abre os cards se achar resultados para facilitar a visualização do usuário
              if (encontrouNoCard) {
                  card.style.display = "block";
                  if ((filtroTextoAtivo !== "" || filtroStatusAtivo !== "") && !card.classList.contains('expanded')) {
                      const header = card.querySelector('.area-header');
                      if (header) header.click(); 
                  }
              } else {
                  card.style.display = "none";
              }
          });
          
          // Limpa a tela ocultando os títulos das subáreas ("LFC 02", "LFC 04"...) se não tiver bolinhas dentro
          document.querySelectorAll('.subarea-container').forEach(sub => {
              const visibleBubbles = Array.from(sub.querySelectorAll('.machine-bubble')).filter(b => b.style.display !== 'none');
              const title = sub.querySelector('.subarea-title');
              if (title) {
                  title.style.display = visibleBubbles.length > 0 ? "block" : "none";
              }
              sub.style.display = visibleBubbles.length > 0 ? "block" : "none";
          });
      }

