                    <h2>RELATÓRIO DE MANUTENÇÃO</h2>
                    <p>Controle Industrial</p>
                </div>
            </div>
            
            <div class="pdf-section">
                <div class="pdf-section-title">Dados Gerais</div>
                <div class="pdf-row"><div class="pdf-label">Data:</div><div class="pdf-value">${r.data}</div></div>
                <div class="pdf-row"><div class="pdf-label">Responsável:</div><div class="pdf-value">${r.tecnico}</div></div>
                <div class="pdf-row"><div class="pdf-label">Máquina:</div><div class="pdf-value">${maqAtu}</div></div>
                ${r.ordemID ? `<div class="pdf-row"><div class="pdf-label">Ordem:</div><div class="pdf-value" style="color:#00AA4E; font-weight:bold;">${r.ordemID}</div></div>` : ''}
            </div>
        `;

        if (d.respostas) { 
            let tit = "Manutenção Preventiva";
            const defUpper = String(r.defeito).toUpperCase();
            if (defUpper.includes("ELÉTRICA")) tit = "Manutenção Preventiva Elétrica";
            else if (defUpper.includes("MECÂNICA")) tit = "Manutenção Preventiva Mecânica";

            let tempoTotal = d.tempo;
            let inicioStr = "N/I";
            let fimStr = "N/I";

            // Parseia a nova string de tempo "X min (Início: DATA - Fim: DATA)"
            if (typeof d.tempo === 'string' && d.tempo.includes("(Início:")) {
                const match = d.tempo.match(/(.*?)\s*\(Início:\s*(.*?)\s*-\s*Fim:\s*(.*?)\)/);
                if (match) {
                    tempoTotal = match[1];
                    inicioStr = match[2];
                    fimStr = match[3];
                }
            }

            htmlPDF += `<div class="pdf-section"><div class="pdf-section-title">${tit}</div>`;
            htmlPDF += `<div class="pdf-row"><div class="pdf-label">Início:</div><div class="pdf-value">${inicioStr}</div></div>`;
            htmlPDF += `<div class="pdf-row"><div class="pdf-label">Fim:</div><div class="pdf-value">${fimStr}</div></div>`;
            htmlPDF += `<div class="pdf-row"><div class="pdf-label">Tempo:</div><div class="pdf-value">${tempoTotal}</div></div>`;
            htmlPDF += `</div>`; // Fecha section inicial para os itens flutuarem livremente

            // FILTRO APLICADO AQUI: Remove os itens que são apenas informativos (OBS)
            const respostasFiltradas = d.respostas.filter(itm => itm.status !== 'OBS');

            respostasFiltradas.forEach((itm, idx) => {
                let statusColor = itm.status === 'OK' ? '#00AA4E' : (itm.status === 'NOK' ? '#dc3545' : '#95a5a6');
