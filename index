        font-size: 18px;
        font-weight: 700;
        margin: 0;
        color: #2c3e50;
      }
      
      .pdf-title p {
        font-size: 12px;
        margin: 0;
        color: #7f8c8d;
      }

      .pdf-section {
        margin-bottom: 20px;
        background: #fdfdfd;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
        /* Evita quebras no cabeçalho das seções */
        page-break-inside: avoid !important;
      }

      .pdf-section-title {
        font-size: 14px;
        font-weight: 700;
        color: #00AA4E;
        text-transform: uppercase;
        border-bottom: 1px solid #eee;
        padding-bottom: 5px;
