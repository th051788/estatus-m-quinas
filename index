      function gerarPDF() {
        if(!dadosRelatorioAtual) return;

        const r = dadosRelatorioAtual.registro;
        const d = dadosRelatorioAtual.detalhes;

        // Montagem do HTML específico para PDF com containers protegidos
        let htmlPDF = `
