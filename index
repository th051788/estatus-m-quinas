      function salvarCorretiva() {
        const dtInicio = document.getElementById('dataInicioCorr').value;
        const hrInicio = document.getElementById('horaInicioCorr').value;
        const dtFim = document.getElementById('dataFimCorr').value;
        const hrFim = document.getElementById('horaFimCorr').value;
        const def = document.getElementById('defeitoCorr').value;
        const causa = document.getElementById('causaCorr').value;
        const acao = document.getElementById('acaoCorr').value;

        if (!dtInicio || !hrInicio || !dtFim || !hrFim) { exibirMensagem("Aviso", "As datas e horários de início e fim são obrigatórios.", "info"); return; }
        
        const startObj = new Date(dtInicio + " " + hrInicio);
        const endObj = new Date(dtFim + " " + hrFim);
        if (endObj <= startObj) {
            exibirMensagem("Aviso", "O horário de 'Fim' deve ser maior que o 'Início'. O tempo de parada não pode ser zero!", "info");
            return;
        }

        const tempo = calcularDowntime(); if (!tempo) return;
        
        if (!def.trim()) { exibirMensagem("Aviso", "A Descrição do Defeito é obrigatória.", "info"); return; }
        if (!causa.trim()) { exibirMensagem("Aviso", "A Causa Raiz é obrigatória.", "info"); return; }
        if (!acao.trim()) { exibirMensagem("Aviso", "A Ação Realizada é obrigatória.", "info"); return; }

        const btn = document.getElementById('btnSalvarCorretiva'); btn.disabled = true; document.getElementById('spinnerBtnSalvarCorr').classList.remove('hidden');
        
        const equipeFinal = [tecAtu, ...equipeAuxiliar]; 

        const dados = {
          inicio: dtInicio + " " + hrInicio,
          fim: dtFim + " " + hrFim,
          tempoParada: tempo, 
          defeito: def, 
          causa: causa,
          acao: acao, 
          tecnicos: equipeFinal, 
          enviarEmail: enviarEmailCorretivaSelecionado,
          trocouPeca: statusAreas.areaPecas, 
          peca: document.getElementById('descPeca').value,
          fotoPecaVelha: statusAreas.areaPecas ? fotosCorretiva.pecaVelha : "",
          fotoPecaNova: statusAreas.areaPecas ? fotosCorretiva.pecaNova : "",
          temFotosServico: statusAreas.areaFotosServico,
          fotoServAntes: statusAreas.areaFotosServico ? fotosCorretiva.servAntes : "",
          fotoServDepois: statusAreas.areaFotosServico ? fotosCorretiva.servDepois : "",
          fotosExtras: statusAreas.areaFotosServico ? normalizarFotosExtrasCorretiva(fotosCorretiva.extras) : []
        };
        google.script.run.withSuccessHandler((msg) => { 
            btn.disabled = false; 
            document.getElementById('spinnerBtnSalvarCorr').classList.add('hidden'); 
            exibirMensagem("Sucesso", msg); 
            
            // LIMPA O RASCUNHO QUANDO O SALVAMENTO É BEM SUCEDIDO
            autoSaveCorretivaHabilitado = false;
            removerRascunhoCorretivaAtual();
            
            // LIMPEZA DA MEMORIA APOS SUCESSO DO UPLOAD!
            fotosCorretiva = { pecaVelha: "", pecaNova: "", servAntes: "", servDepois: "", extras: [] };
            
            toggleTelas('telaRegistroCorretiva', 'telaOpcoes'); 
        }).salvarRegistroCorretiva(tecAtu, maqAtu, dados);
      }

