                     htmlPDF += `<div style="margin-top:15px; font-weight:bold; font-size:12px; color:#555;">Fotos Extras:</div><div class="pdf-images">`;
                     d.fotosExtras.forEach((ex, idx) => {
                        const urlExtra = typeof ex === 'string' ? ex : ex.imagem;
                        const comentarioExtra = ex && typeof ex === 'object' && ex.comentario ? `<div class="pdf-img-label">${String(ex.comentario).replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>` : '';
                        htmlPDF += `<div class="pdf-img-box"><img src="${urlExtra}" class="pdf-img"><div class="pdf-img-label">EXTRA ${idx+1}</div>${comentarioExtra}</div>`;
                     });
                     htmlPDF += `</div>`;
                }
                htmlPDF += `</div>`;
            }
        }

        // Criar elemento temporário
        const wrapper = document.createElement('div');
        wrapper.className = 'pdf-wrapper';
        wrapper.innerHTML = htmlPDF;

        // Opções do PDF (Com correção para não quebrar componentes css com propriedades avoid)
        const opt = {
          margin:       0.5,
          filename:     `Relatorio_${maqAtu}_${new Date().toLocaleDateString()}.pdf`,
