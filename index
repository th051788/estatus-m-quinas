                btn.disabled = false;
                document.getElementById('containerCardsMaquinas').innerHTML = '<div class="text-center py-5 text-danger"><i class="bi bi-exclamation-triangle-fill"></i><p class="mt-2 small">Erro ao sincronizar catálogo de máquinas.</p></div>';
