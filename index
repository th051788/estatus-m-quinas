<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Intelmes - Monitoramento Industrial</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&family=Orbitron:wght@500;700&display=swap" rel="stylesheet">

  <style>
    /* ==============================
        🎨 TEMA: LAYOUT INTELMES
        ============================== */
    :root {
        --bg-body: #F4F7F6; 
        --sidebar-bg: #1B9E44;
        --header-bg: #E9EDEE;
        --text-dark: #334D5C;
        --color-op: #00CC44;
        --color-man: #FF3B30;
        --color-desl: #7f8c8d;
        --color-atu: #1E88E5;
        --color-ocup: #8E44AD;
    }

    html, body {
      margin: 0;
      padding: 0;
      width: 100vw;
      height: 100vh;
      background-color: var(--bg-body);
      overflow-x: hidden;
      /* Permitir scroll vertical suave se necessário, mas evitar o "balanço" do zoom */
    }

    body {
      font-family: 'Roboto', sans-serif;
      color: var(--text-dark);
    }

    /* Container Principal - Removida a transição de transform para parar o balanço */
    #app-scale-container {
      display: flex;
      width: 100vw; 
      min-height: 100vh;
      transform-origin: top left;
      /* Removido o transition: transform para evitar o efeito de "tela se mexendo" */
    }

    #audio-overlay {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.85);
      z-index: 10000;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      color: white;
      cursor: pointer;
      text-align: center;
    }

    .activate-btn {
      background: var(--sidebar-bg);
      color: white;
      border: none;
      padding: 20px 40px;
      font-size: 1.5rem;
      font-weight: bold;
      border-radius: 50px;
      margin-top: 20px;
      cursor: pointer;
      font-family: 'Orbitron';
      box-shadow: 0 0 20px rgba(27, 158, 68, 0.5);
    }

    .sidebar {
      width: 50px;
      background-color: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 15px;
      gap: 20px;
      flex-shrink: 0;
    }

    .sidebar-icon {
      color: white;
      font-size: 20px;
      opacity: 0.8;
      cursor: pointer;
    }

    .main-wrapper {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      background-color: var(--bg-body);
      width: 100%;
    }

    .top-nav {
      height: 50px;
      background-color: var(--header-bg);
      display: flex;
      align-items: center;
      padding: 0 20px;
      justify-content: space-between;
      border-bottom: 1px solid #D1D8D9;
    }

    .top-left-info {
      display: flex;
      align-items: center;
      gap: 20px;
      font-size: 0.85rem;
      font-weight: 500;
    }

    .logo-intelmes {
      font-family: 'Orbitron', sans-serif;
      color: #1B9E44;
      font-size: 1.8rem;
      font-weight: 900;
      letter-spacing: -1px;
    }

    .sub-header {
      background-color: #BDBDBD;
      padding: 10px 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 15px;
    }

    .nav-btn {
      background-color: #47A969;
      color: white;
      border: none;
      padding: 6px 30px;
      font-weight: bold;
      border-radius: 4px;
      text-transform: uppercase;
      font-size: 0.8rem;
    }

    .content-container {
      padding: 20px;
      flex-grow: 1;
    }

    /* Otimização do Grid para encaixar melhor */
    .maquinas-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    h2 {
      font-family: 'Orbitron', sans-serif;
      font-size: 1.2rem;
      color: var(--text-dark);
      border-left: 5px solid var(--sidebar-bg);
      padding-left: 12px;
      margin-top: 25px;
      margin-bottom: 15px;
    }

    .card-intelmes {
      border-radius: 8px;
      color: white;
      padding: 15px;
      display: flex;
      flex-direction: column;
      box-shadow: 0 4px 10px rgba(0,0,0,0.15);
      min-height: 190px;
      position: relative;
    }

    .card-intelmes.op { background-color: var(--color-op); }
    .card-intelmes.man { background-color: var(--color-man); }
    .card-intelmes.desl { background-color: var(--color-desl); }
    .card-intelmes.atu { background-color: var(--color-atu); }
    .card-intelmes.ocup { background-color: var(--color-ocup); }

    .card-title {
      font-size: 1.6rem;
      font-weight: 900;
      margin: 8px 0;
      text-align: center;
      letter-spacing: -0.5px;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
    }

    .card-status-pill {
      background: rgba(0,0,0,0.15);
      padding: 10px;
      border-radius: 6px;
      text-align: center;
      font-weight: 900;
      font-size: 1.1rem;
      text-transform: uppercase;
      margin: 5px 0;
    }

    .card-update-area {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      margin-top: 10px;
    }

    .update-time-box {
      font-size: 0.9rem;
      font-weight: bold;
      background: rgba(255,255,255,0.2);
      padding: 4px 15px;
      border-radius: 20px;
    }

    .card-footer {
      margin-top: 12px;
      padding-top: 8px;
      border-top: 1px solid rgba(255,255,255,0.2);
      font-size: 0.75rem;
      font-weight: bold;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .diesel-panel {
      background: white;
      margin-bottom: 20px;
      border-radius: 12px;
      padding: 15px;
      display: flex;
      align-items: center;
      gap: 30px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
      border: 1px solid #D1D8D9;
      width: fit-content;
    }

    #gaugeDiesel { width: 140px; height: 70px; }

    @keyframes pulseAlert {
      0% { box-shadow: 0 0 0 rgba(255, 59, 48, 0); }
      50% { box-shadow: 0 0 20px rgba(255, 59, 48, 0.8) inset, 0 0 15px rgba(255, 59, 48, 0.6); }
      100% { box-shadow: 0 0 0 rgba(255, 59, 48, 0); }
    }
    .pulse-vermelho { animation: pulseAlert 1.5s infinite; }

    footer {
        padding: 15px 25px; 
        text-align: right; 
        background: #E9EDEE; 
        font-size: 0.75rem; 
        border-top: 1px solid #D1D8D9; 
        color: #7F8C8D;
    }
  </style>
</head>

<body>

<div id="audio-overlay" onclick="ativarMonitoramento()">
  <h1 style="font-family: 'Orbitron'; margin: 0;">SISTEMA INTELMES</h1>
  <p style="font-size: 1.2rem; opacity: 0.8; max-width: 500px; margin-top: 15px;">
    Clique para cobrir a tela inteira da TV e ativar o áudio.
  </p>
  <button class="activate-btn">INICIAR MONITORAMENTO</button>
</div>

<div id="app-scale-container">
    <div class="sidebar">
      <div class="sidebar-icon">🏠</div>
      <div class="sidebar-icon">📊</div>
      <div class="sidebar-icon">📝</div>
      <div class="sidebar-icon">🔧</div>
      <div class="sidebar-icon" onclick="toggleFullscreen()" title="Tela Cheia">⛶</div>
      <div class="sidebar-icon" onclick="toggleMute()" title="Alternar Som">🔇</div>
    </div>

    <div class="main-wrapper">
      <div class="top-nav">
        <div class="top-left-info">
          <span>CENTRO</span>
          <span style="color: #7f8c8d;">1004 - Intelbras Manaus - Filial</span>
          <span id="clock" style="font-size: 1.4rem; font-weight: bold; color: var(--text-dark); margin-left: 15px;">00:00:00</span>
        </div>
        <div class="logo-intelmes">intelmes</div>
        <div style="font-size: 1.5rem; cursor: pointer; opacity: 0.5;">❓</div>
      </div>

      <div class="sub-header">
        <button class="nav-btn">MÁQUINAS</button>
        <button class="nav-btn" style="background: #62A87C;">MONTAGEM</button>
        <div style="font-size: 0.8rem; font-weight: bold; color: #444;">OEE ●</div>
      </div>

      <div class="content-container">
        <div class="diesel-panel">
          <div style="position: relative;">
            <canvas id="gaugeDiesel"></canvas>
            <div id="gaugeLabel" style="position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); font-weight: bold; font-family: Orbitron; font-size: 1.3rem;">--%</div>
          </div>
          <div>
            <div style="font-weight: 900; color: #95A5A6; font-size: 0.75rem; letter-spacing: 2px;">NÍVEL DIESEL</div>
            <div id="dieselStatus" style="font-size: 1.6rem; font-weight: bold; color: var(--text-dark);">Conectando...</div>
          </div>
        </div>

        <h2 id="section-montagem">Montagem Final</h2>
        <div class="maquinas-grid" id="montagem"></div>

        <h2 id="section-injeplast">Injeção Plástica</h2>
        <div class="maquinas-grid" id="injeplast"></div>

        <h2 id="section-geral">Geral</h2>
        <div class="maquinas-grid" id="geral"></div>
      </div>

      <footer>
        Intelmes Interface v6.7 • Thiago Costa © 2025
      </footer>
    </div>
</div>

<script>
let muted = false;
let ultimaLeitura = {};
let primeiraAtualizacaoPronta = false;
let monitoramentoAtivo = false;

// Estabilização do Zoom: Só muda o zoom se houver uma alteração real de tamanho de janela
function ajustarZoomAutomatico() {
  const container = document.getElementById('app-scale-container');
  if (!container) return;
  
  container.style.transform = 'scale(1)';
  container.style.width = '100vw'; 
  
  const winHeight = window.innerHeight;
  const contentHeight = container.scrollHeight;
  
  let scale = 1;
  // Só aplicamos escala se o conteúdo realmente estourar a altura da TV
  if (contentHeight > winHeight) {
    scale = (winHeight / contentHeight) * 0.98; // 2% de margem de segurança
  }

  container.style.transform = `scale(${scale})`;
  container.style.width = (100 / scale) + "vw";
}

window.addEventListener('resize', ajustarZoomAutomatico);

function updateClock() {
  const clock = document.getElementById('clock');
  if (clock) clock.textContent = new Date().toLocaleTimeString('pt-BR');
}
setInterval(updateClock, 1000);

function falarNativo(texto) {
  if ('speechSynthesis' in window) {
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(texto);
    utterance.lang = 'pt-BR';
    utterance.rate = 0.9; // Um pouco mais lento para clareza
    window.speechSynthesis.speak(utterance);
  }
}

async function falar(texto) {
  if (muted || !monitoramentoAtivo) return;
  try {
    const resposta = await fetch(
      'https://texttospeech.googleapis.com/v1/text:synthesize?key=AIzaSyAp3-ylkpHM1Z6W_AAznBK-XtQOeCVbebA',
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          input: { text: texto },
          voice: { languageCode: "pt-BR", ssmlGender: "MALE" },
          audioConfig: { audioEncoding: "MP3", speakingRate: 1.0, pitch: -2.0 }
        })
      }
    );
    if (!resposta.ok) throw new Error();
    const data = await resposta.json();
    if (data.audioContent) {
      const audio = new Audio("data:audio/mp3;base64," + data.audioContent);
      audio.play().catch(() => falarNativo(texto));
    } else {
      falarNativo(texto);
    }
  } catch (e) { falarNativo(texto); }
}

function atualizarGauge(valor, cor, statusTexto) {
  const label = document.getElementById("gaugeLabel");
  const statusEl = document.getElementById("dieselStatus");
  if (label) label.textContent = valor + "%";
  if (statusEl) statusEl.textContent = statusTexto; 
  const canvas = document.getElementById('gaugeDiesel');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const w = canvas.width = 140;
  const h = canvas.height = 70;
  ctx.clearRect(0, 0, w, h);
  const cx = w / 2;
  const cy = h - 5;
  const r = 60;
  ctx.beginPath(); ctx.arc(cx, cy, r, Math.PI, 2 * Math.PI); 
  ctx.strokeStyle = "#D1D8D9"; ctx.lineWidth = 12; ctx.stroke();
  const end = Math.PI + (valor / 100) * Math.PI;
  ctx.beginPath(); ctx.arc(cx, cy, r, Math.PI, end); 
  ctx.strokeStyle = cor; ctx.lineWidth = 12; ctx.stroke();
}

async function atualizarPainel() {
  if (!monitoramentoAtivo) return;
  try {
    const response = await fetch('https://script.google.com/macros/s/AKfycbyrJXaPnJK6AIjCMhsFM0biTKU8byzu8ST-jtOObOtpWSIRxcsyPzMzl7VsJeMSuIV5uV/exec?func=getData');
    const data = await response.json();
    const cardsAtuaisNaTela = {};

    data.forEach((item, index) => {
      const nomeID = nomePadrao(item.maquina);
      const cardId = `card-${index}-${nomeID}`;
      const chaveVoz = `voz-${index}-${nomeID}`;
      const statusFormatado = removerAcentos(item.status).trim();

      if (nomeID.includes("tanquediesel")) {
        let l = parseFloat(item.status);
        let p = isNaN(l) ? 0 : Math.min(100, (l / 1000) * 100);
        let c = p > 70 ? "#00CC44" : (p > 40 ? "#FF9800" : "#FF3B30");
        atualizarGauge(p.toFixed(0), c, `${l} Litros`);
        return;
      }

      // LÓGICA DE VOZ AJUSTADA
      if (primeiraAtualizacaoPronta && ultimaLeitura[chaveVoz] !== undefined && ultimaLeitura[chaveVoz] !== statusFormatado) {
          if (statusFormatado !== "on" && statusFormatado !== "aterramento em condicao normal") {
              
              let statusFala = item.status;
              
              // Ajuste específico para o Alarme de Incêndio
              if (statusFormatado.includes("incendio")) {
                statusFala = "Atenção: Pré alarme de incêndio acionado.";
              } else {
                if (statusFormatado === "operacao") statusFala = "Ligado";
                if (statusFormatado === "informacao") statusFala = "Informação";
              }
              
              if (["thiago","ederlan","hudson","igor"].includes(statusFormatado)) {
                 falar("Atenção. Equipe na subestação.");
              } else {
                 falar(`${nomeBonito(item.maquina)}. ${statusFala}`);
              }
          }
      }
      
      ultimaLeitura[chaveVoz] = statusFormatado;

      if (statusFormatado === "on" || statusFormatado === "aterramento em condicao normal") {
        const ex = document.getElementById(cardId); if (ex) ex.remove(); return;
      }

      cardsAtuaisNaTela[cardId] = true;
      let classe = "man"; let tempoCritico = false;
      let atualizadoDate = item.atualizado.includes(":") ? new Date(item.atualizado.split("/").reverse().join(" ")) : new Date(item.atualizado.split("/").reverse().join(" ") + ' 00:00');
      const agora = new Date(); const minutosPassados = (agora - atualizadoDate) / 60000;

      if (["operacao","produzindo","energizado","condicao normal","concluido","realizado","pressurizado"].includes(statusFormatado)) classe = "op";
      else if (["manutencao","emergencia","elemento","desenergizado","alerta de alta temperatura","fuga de tensao","patinando","atrasado","bomba em alarme"].includes(statusFormatado)) {
        classe = "man"; if (minutosPassados > 30) tempoCritico = true;
      }
      else if (["tecnico atuando na maquina","nao produzindo","preencher checklist"].includes(statusFormatado)) classe = "atu";
      else if (["desligado","pendente"].includes(statusFormatado)) classe = "desl";
      else if (["thiago","ederlan","hudson","igor","informacao"].includes(statusFormatado)) classe = "ocup";

      let statusExibicao = item.status;
      if (statusFormatado === "operacao") statusExibicao = "Ligado";
      if (statusFormatado === "desligado") statusExibicao = "Desligado";
      if (statusFormatado === "realizado") statusExibicao = "Realizado";
      if (statusFormatado === "informacao") statusExibicao = "Informação";

      const html = `
        <div style="font-size: 0.7rem; font-weight: bold; opacity: 0.8;">STATUS ATUAL</div>
        <div class="card-title">${item.maquina.toUpperCase()}</div>
        <div class="card-status-pill">${statusExibicao}</div>
        <div class="card-update-area"><div class="update-time-box">${item.atualizado}</div></div>
        <div class="card-footer"><span>${nomeID.toUpperCase()}</span>${item.responsavel ? `<span style="color:#FFD700">👷 ${item.responsavel}</span>` : '<div class="info-icon" style="background:rgba(255,255,255,0.3);width:16px;height:16px;display:flex;align-items:center;justify-content:center;border-radius:3px;font-size:9px;">IT</div>'}</div>
      `;

      let card = document.getElementById(cardId);
      if (!card) {
        card = document.createElement("div"); card.id = cardId;
        const grupo = removerAcentos(item.grupo);
        const target = grupo.includes("montagem") ? document.getElementById("montagem") : (grupo.includes("injecao") || grupo.includes("plastica")) ? document.getElementById("injeplast") : document.getElementById("geral");
        if (target) target.appendChild(card);
      }
      card.className = `card-intelmes ${classe} ${tempoCritico ? 'pulse-vermelho' : ''}`;
      card.innerHTML = html;
    });

    document.querySelectorAll('.card-intelmes').forEach(c => { if (!cardsAtuaisNaTela[c.id]) c.remove(); });
    
    // Chamamos o ajuste apenas se o número de cards mudou drasticamente ou na primeira carga
    ajustarZoomAutomatico();
    primeiraAtualizacaoPronta = true;
  } catch (e) { console.error("Update Error:", e); }
}

function ativarMonitoramento() {
  monitoramentoAtivo = true;
  document.getElementById('audio-overlay').style.display = 'none';
  ajustarZoomAutomatico();
  falar("Monitoramento iniciado.");
  atualizarPainel();
}

function removerAcentos(t) { return t ? t.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase() : ""; }
function nomePadrao(t) { return removerAcentos(t).replace(/\s+/g, ""); }
function nomeBonito(m) { return m.charAt(0).toUpperCase() + m.slice(1); }
function toggleFullscreen() { if (!document.fullscreenElement) document.documentElement.requestFullscreen(); else document.exitFullscreen(); }
function toggleMute() { muted = !muted; const btn = document.querySelector('.sidebar-icon[onclick="toggleMute()"]'); if(btn) btn.textContent = muted ? '🔈' : '🔇'; }

setInterval(atualizarPainel, 5000);
</script>

</body>
</html>
