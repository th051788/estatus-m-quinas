function salvarInformacaoMaquina(maquina, tecnico, informacao) {
  try {
    const local = getMachineSheet(maquina);
    if (!local) return "Erro: Máquina não encontrada.";
    
    // Salva na célula N5 da aba da máquina
    local.sheet.getRange("N5").setValue(informacao);
    
    // Registra no histórico que a informação foi alterada
    local.sheet.appendRow([new Date(), tecnico, "STATUS", "Informação/Aviso Atualizado", "OK", JSON.stringify({aviso: informacao})]);
    
    // --- INTEGRAÇÃO: Salvar na planilha externa de informações ---
    try {
        const ssInfo = SpreadsheetApp.openById(PLANILHA_INFORMACOES_ID);
        const abaInfo = ssInfo.getSheetByName("Página1");
        if (abaInfo) {
            const dadosInfo = abaInfo.getDataRange().getValues();
            let linhaEncontrada = -1;
            const dataAtual = Utilities.formatDate(new Date(), "GMT-3", "dd/MM/yyyy HH:mm:ss");

            for (let i = 0; i < dadosInfo.length; i++) {
                if (String(dadosInfo[i][0]).trim() === String(maquina).trim()) {
                    linhaEncontrada = i + 1; // +1 porque o array começa em 0 e as linhas no sheets em 1
                    break;
                }
            }

            if (linhaEncontrada !== -1) {
                abaInfo.getRange(linhaEncontrada, 2).setValue(informacao); // Coluna B
                abaInfo.getRange(linhaEncontrada, 3).setValue(dataAtual);  // Coluna C
            } else {
                abaInfo.appendRow([maquina, informacao, dataAtual]);
            }
        }
    } catch (erroInfo) {
        console.log("Erro ao salvar na planilha externa de informações: " + erroInfo.message);
    }
    
    return "Aviso salvo com sucesso na aba do equipamento e no painel geral!";
  } catch(e) {
    return "Erro ao salvar: " + e.message;
  }
}

function apagarInformacaoMaquina(maquina) {
  try {
    const local = getMachineSheet(maquina);
    if (!local) return "Erro: Máquina não encontrada.";
    local.sheet.getRange("N5").clearContent();

    // --- INTEGRAÇÃO: Apagar da planilha externa de informações ---
    try {
        const ssInfo = SpreadsheetApp.openById(PLANILHA_INFORMACOES_ID);
        const abaInfo = ssInfo.getSheetByName("Página1");
        if (abaInfo) {
            const dadosInfo = abaInfo.getDataRange().getValues();
            for (let i = 0; i < dadosInfo.length; i++) {
                if (String(dadosInfo[i][0]).trim() === String(maquina).trim()) {
                    // Limpa a informação (Col B) e a data (Col C) na planilha externa
                    abaInfo.getRange(i + 1, 2).clearContent();
                    abaInfo.getRange(i + 1, 3).clearContent();
                    break;
                }
            }
        }
    } catch (erroInfo) {
        console.log("Erro ao apagar na planilha externa de informações: " + erroInfo.message);
    }

    return "Informação removida com sucesso.";
  } catch(e) { return "Erro: " + e.message; }
}
