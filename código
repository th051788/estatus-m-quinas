/**
 * Função Auxiliar para localizar a aba de uma máquina em qualquer uma das planilhas configuradas
 */
function getMachineSheet(idMaquina) {
  const ssPrincipal = getSS();
  const ssSetup = getSSSetup();
  const ssSMT = getSS_SMT();
  const ssTeste = getSS_TESTE();
  const ssFerramentaria = getSS_FERRAMENTARIA();
  
  // Procura na principal
  let sheet = ssPrincipal.getSheetByName(idMaquina);
  if (sheet) return { sheet: sheet, ss: ssPrincipal };
  
  // Procura no setup
  sheet = ssSetup.getSheetByName(idMaquina);
  if (sheet) return { sheet: sheet, ss: ssSetup };

  // Procura no SMT
  sheet = ssSMT.getSheetByName(idMaquina);
  if (sheet) return { sheet: sheet, ss: ssSMT };

  // Procura na Teste
  sheet = ssTeste.getSheetByName(idMaquina);
  if (sheet) return { sheet: sheet, ss: ssTeste };

  // Procura na Ferramentaria
  sheet = ssFerramentaria.getSheetByName(idMaquina);
  if (sheet) return { sheet: sheet, ss: ssFerramentaria };
  
  return null; // Não encontrado
}

/**
 * Normaliza texto para comparação (Remove acentos, espaços extras e coloca em MAIÚSCULO)
 */
function normalizarTexto(texto) {
  if (!texto) return "";
  return String(texto).toUpperCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
}

/**
 * Extrai números
 */
function extrairNumeros(texto) {
  const nums = String(texto).match(/\d+/g);
  return nums ? nums.map(n => parseInt(n, 10)) : [];
}

/**
 * NOVO: Extrai apenas o número da ordem (ex: de "MOINHO 3 (4025208)" tira só "4025208")
 */
function extrairApenasNumeroOrdem(textoOrdem) {
  if (!textoOrdem) return "";
  let texto = String(textoOrdem);
  
  // Tenta achar o número que está entre parênteses
  let match = texto.match(/\((\d+)\)/);
  if (match) return match[1];
  
  // Se não achar parênteses, pega a maior sequência de números
  let nums = texto.match(/\d+/g);
  if (nums) {
      return nums.reduce((max, curr) => curr.length > max.length ? curr : max, "");
  }
  
  return texto;
}

