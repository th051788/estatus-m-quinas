function criarBlobDeBase64(base64Data, nomeArquivo) {
  try {
    if (!base64Data || !base64Data.includes("base64,")) return null;
    const parts = base64Data.split("base64,");
    const contentType = parts[0].replace("data:", "").replace(";", "");
    const data = parts[1];
    const decoded = Utilities.base64Decode(data);
    return Utilities.newBlob(decoded, contentType, nomeArquivo);
  } catch (e) {
    console.log("Erro ao converter imagem: " + e.message);
    return null;
  }
}

