/**
 * VERIFICAR ORDEM PREVENTIVA COM SELEÇÃO INTELIGENTE DE ABA E CORREÇÃO DE BUSCA EXATA
 */
function verificarOrdemPreventiva(maquina, tecnico) {
  try {
    const ss = getSSOrdens();
    const tecUpper = tecnico.toUpperCase().trim();
    
    // Mapeamento de Times vs Abas
    const timeTeste = ["ODANIR", "ANDERSON", "CEZAR"];
    const timeSMT = ["DAYANNE", "FELIPE ALMEIDA", "OTNIEL", "RAINE", "ROGERIO", "ANSELMO", "WALMIR"];
    const timeFerramentaria = ["SELBERTHS"];
    
    let nomeAba = "MF+INJ"; // Default
    
    if (timeTeste.includes(tecUpper)) {
      nomeAba = "TESTE";
    } else if (timeSMT.includes(tecUpper)) {
      nomeAba = "SMT";
    } else if (timeFerramentaria.includes(tecUpper)) {
      nomeAba = "MOLDE";
    }
    
    const aba = ss.getSheetByName(nomeAba);
    if (!aba) {
      console.warn("Aba " + nomeAba + " não encontrada. Usando a primeira.");
      return { encontrou: false, erro: "Aba de ordens (" + nomeAba + ") não encontrada." };
    }

    const dados = aba.getDataRange().getValues();
    dados.shift(); // Remove cabeçalho

    const maquinaNorm = normalizarTexto(maquina);
    const tecnicoNorm = normalizarTexto(tecnico);

    // Loop pelas ordens da planilha
    for (let i = 0; i < dados.length; i++) {
      const row = dados[i];
      const txtOrdem = String(row[0] || ""); // Coluna A (Ex: "MOLDE-1 (4025461)")
      const txtTecnico = String(row[4] || ""); // Coluna E
      const txtStatus = String(row[5] || ""); // Coluna F

      if (!txtOrdem || txtOrdem.length < 2) continue;

      const statusNorm = normalizarTexto(txtStatus);
      const isConcluido = statusNorm.includes("CONCLUIDO") || statusNorm.includes("CONFIRMADO");
      const isPendente = statusNorm.includes("ATRASO") || statusNorm.includes("EM DIA");
      
      if (isConcluido || !isPendente) continue;

      const rowTecNorm = normalizarTexto(txtTecnico);
      if (!rowTecNorm.includes(tecnicoNorm) && !tecnicoNorm.includes(rowTecNorm)) continue;

      /**
       * CORREÇÃO APLICADA: 
       * Extraímos o nome do equipamento (antes do parênteses) para comparar de forma exata.
       * Isso evita que "MOLDE-1" pegue ordens de "MOLDE-14".
       */
      let nomeEquipamentoNaOrdem = txtOrdem.split('(')[0].trim();
      
      if (normalizarTexto(nomeEquipamentoNaOrdem) === maquinaNorm) {
        return { encontrou: true, ordem: txtOrdem, status: txtStatus };
      }
    }
    return { encontrou: false };
  } catch (e) { return { erro: e.message }; }
}

