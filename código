/**
 * BUSCAR ORDENS PENDENTES DO TÉCNICO (OU DE TODOS SE FOR PRODUÇÃO) PARA COLORIR A LISTA DE MÁQUINAS
 */
function buscarOrdensPendentes(tecnico) {
  try {
    const ss = getSSOrdens();
    if (!tecnico) return [];

    const isProducao = (tecnico === "Produção");
    const tecUpper = tecnico.toUpperCase().trim();
    
    // Se for produção, varre todas as abas. Se não, varre só a do técnico.
    let abasParaBuscar = ["MF+INJ"]; // Default
    if (isProducao) {
        abasParaBuscar = ["MF+INJ", "TESTE", "SMT", "MOLDE"];
    } else {
        const timeTeste = ["ODANIR", "ANDERSON", "CEZAR"];
        const timeSMT = ["DAYANNE", "FELIPE ALMEIDA", "OTNIEL", "RAINE", "ROGERIO", "ANSELMO", "WALMIR"];
        const timeFerramentaria = ["SELBERTHS"];
        
        if (timeTeste.includes(tecUpper)) abasParaBuscar = ["TESTE"];
        else if (timeSMT.includes(tecUpper)) abasParaBuscar = ["SMT"];
        else if (timeFerramentaria.includes(tecUpper)) abasParaBuscar = ["MOLDE"];
    }

    const tecnicoNorm = normalizarTexto(tecnico);
    const limparIdentificador = (t) => normalizarTexto(t).replace(/[^A-Z0-9]/g, "").replace(/0+([0-9]+)/g, "$1");

    let pendentes = [];

    // Percorre as abas definidas
    abasParaBuscar.forEach(nomeAba => {
        const aba = ss.getSheetByName(nomeAba);
        if (!aba) return;

        const dados = aba.getDataRange().getValues();
        dados.shift(); // Remove cabeçalho

        for (let i = 0; i < dados.length; i++) {
          const row = dados[i];
          const txtOrdem = String(row[0] || ""); // Coluna A
          const txtTecnico = String(row[4] || ""); // Coluna E
          const txtStatus = String(row[5] || ""); // Coluna F

          if (!txtOrdem || txtOrdem.length < 2) continue;

          const statusNorm = normalizarTexto(txtStatus);
          const isConcluido = statusNorm.includes("CONCLUIDO") || statusNorm.includes("CONFIRMADO");
          const isPendente = statusNorm.includes("ATRASO") || statusNorm.includes("EM DIA");
          
          if (isConcluido || !isPendente) continue;

          // Se NÃO for produção, exige que o nome do técnico esteja na ordem. 
          if (!isProducao) {
              const rowTecNorm = normalizarTexto(txtTecnico);
              if (!rowTecNorm.includes(tecnicoNorm) && !tecnicoNorm.includes(rowTecNorm)) continue;
          }

          /**
           * CORREÇÃO AQUI TAMBÉM: Usamos o nome do equipamento para o ID limpo que colore os cards
           */
          let nomeEq = txtOrdem.split('(')[0].trim();
          const idOrdemLimpo = limparIdentificador(nomeEq);
          const tipoStatus = statusNorm.includes("ATRASO") ? "ATRASADO" : "EM DIA";

          pendentes.push({ idLimpo: idOrdemLimpo, status: tipoStatus });
        }
    });

    return pendentes;
  } catch (e) { return []; }
}

