function buscarHistoricoMaquina(idMaquina) {
  try {
    const local = getMachineSheet(idMaquina);
    
    if (!local || local.sheet.getLastRow() === 0) {
      return { lista: [], disponibilidade: "100%", mttr: "0", mtbf: "---", topDefeitos: [] };
    }

    const dados = local.sheet.getDataRange().getValues();
    
    if (dados.length > 0 && String(dados[0][0]).toUpperCase() === "DATA") {
      dados.shift(); 
    }

    const historico = dados.map(r => {
      let detalhesJSONStr = String(r[5] || "");
      let ordem = "";
      
      // Tenta ler a ordem de dentro do JSON se existir (Importante para a Preventiva)
      try {
          let parsed = JSON.parse(detalhesJSONStr);
          // Usa a função para garantir que registros antigos com nome longo fiquem limpos
          if (parsed.ordemID) ordem = extrairApenasNumeroOrdem(parsed.ordemID);
      } catch(e) {}

      return {
        data: r[0] instanceof Date ? Utilities.formatDate(r[0], "GMT-3", "dd/MM/yyyy") : String(r[0]),
        tecnico: String(r[1] || "---"),
        tipo: String(r[2] || "Geral"),
        defeito: String(r[3] || "Sem descrição"),
        status: String(r[4] || "-"),
        detalhes: detalhesJSONStr,
        ordemID: ordem
      };
    }).filter(r => r.tecnico !== "---").reverse();

    const corretivas = historico.filter(h => h.tipo && h.tipo.toUpperCase().includes("CORRETIVA"));
    const qtdFalhas = corretivas.length;
    
    let disp = "100%";
    let mttrVal = "0"; 
    let mtbfVal = "---"; 
    let topDefeitos = [];

    if (qtdFalhas > 0) {
        let tempoTotalReparoHoras = 0;
        let contagemDefeitos = {};

        // LÊ O TEMPO REAL DE PARADA E OS DEFEITOS DE CADA CORRETIVA
        corretivas.forEach(corr => {
            // Contagem de Defeitos
            let def = String(corr.defeito).trim();
            if (def && def.toUpperCase() !== "SEM DESCRIÇÃO" && def !== "-" && def !== "") {
                let key = def.toUpperCase();
                if (!contagemDefeitos[key]) {
                    contagemDefeitos[key] = { text: def, count: 0 };
                }
                contagemDefeitos[key].count++;
            }

            // Cálculo do Tempo
            try {
                const det = JSON.parse(corr.detalhes);
                const strTempo = det.tempoParada || ""; // Ex: "1h 30min" ou "45 min"
                let horas = 0;
                let mins = 0;

                // Extrai horas e minutos do texto
                if (strTempo.includes("h")) {
                    const partes = strTempo.split("h");
                    horas = parseInt(partes[0].trim()) || 0;
                    if (partes[1] && partes[1].includes("min")) {
                        mins = parseInt(partes[1].replace("min", "").trim()) || 0;
                    }
                } else if (strTempo.includes("min")) {
                    mins = parseInt(strTempo.replace("min", "").trim()) || 0;
                }

                // Soma ao tempo total em formato decimal (Ex: 1h 30min = 1.5 horas)
                tempoTotalReparoHoras += (horas + (mins / 60));
            } catch (e) {
                // Ignora se não conseguir ler o JSON
            }
        });

        // Extrai os Top 3 Defeitos
        topDefeitos = Object.values(contagemDefeitos)
            .sort((a, b) => b.count - a.count)
            .slice(0, 3)
            .map(item => item.text);

        // Assumindo um baseline de 1 mês produtivo (30 dias x 24h = 720 horas)
        const tempoOperacional = 720; 
        
        // Evita que o tempo de reparo seja maior que o tempo operacional no cálculo
        if (tempoTotalReparoHoras > tempoOperacional) {
            tempoTotalReparoHoras = tempoOperacional; 
        }
        
        // CÁLCULOS REAIS
        const mttrReal = tempoTotalReparoHoras / qtdFalhas;
        const mtbfCalc = (tempoOperacional - tempoTotalReparoHoras) / qtdFalhas;
        const dispCalc = ((tempoOperacional - tempoTotalReparoHoras) / tempoOperacional) * 100;

        mttrVal = mttrReal.toFixed(1);
        mtbfVal = mtbfCalc.toFixed(0);
        disp = dispCalc.toFixed(1) + "%";
    }

    return { lista: historico, disponibilidade: disp, mttr: mttrVal, mtbf: mtbfVal, topDefeitos: topDefeitos };
  } catch (e) {
    return { erro: e.message };
  }
}

/**
 * BUSCAR ITENS CHECKLIST - ATUALIZADO PARA NOVA ESTRUTURA COM 3 COLUNAS
 */
function buscarItensChecklist(idMaquina, tecnico) {
  try {
    const local = getMachineSheet(idMaquina);
    if (!local) return { itens: [], tipo: "ERRO" };
    
    const tecUpper = tecnico.toUpperCase().trim();
    
    // Definição das equipes para distribuir as colunas
    const timeSetup = ["DAYANE SILVA", "JOSE VAILTON", "SOFIA DA SILVA", "WENDERSON CASTRO", "RENAN", "VINICIUS"];
    const timeSMT = ["DAYANNE", "FELIPE ALMEIDA", "OTNIEL", "RAINE", "ROGERIO", "ANSELMO", "WALMIR"];
    const timeTeste = ["ODANIR", "ANDERSON", "CEZAR"];
    const timeEletrica = ["HUDSON", "ROBERTHY", "IGOR", "THIAGO", "EDERLAN"];
    const timeFerramentaria = ["SELBERTHS"];

    // Configuração Padrão: Mecânica (Coluna P)
    let colIndex = 15; // Coluna P (índice 15 no zero-based array do GAS)
    let tipo = "MECÂNICA";

    // Mapeamento de colunas por equipe
    if (timeSetup.includes(tecUpper)) {
      colIndex = 19; // Coluna T (índice 19) -> Lê T (Pergunta), U (OBS), V (Imagem)
      tipo = "SETUP";
    } else if (timeEletrica.includes(tecUpper)) {
      colIndex = 19; // Coluna T (índice 19) -> Lê T (Pergunta), U (OBS), V (Imagem)
      tipo = "ELÉTRICA";
    } else if (timeTeste.includes(tecUpper)) {
      colIndex = 15; // Coluna P (índice 15) -> Lê P (Pergunta), Q (OBS), R (Imagem)
      tipo = "TESTE";
    } else if (timeSMT.includes(tecUpper)) {
      colIndex = 15; // Coluna P
      tipo = "SMT";
    } else if (timeFerramentaria.includes(tecUpper)) {
      colIndex = 15; // Coluna P
      tipo = "FERRAMENTARIA";
    }

    const lastRow = local.sheet.getLastRow();
    if (lastRow < 2) return { itens: [], tipo: tipo };

    // Puxa as 3 colunas a partir da coluna inicial mapeada acima (Pergunta, Gatilho OBS, Link Imagem)
    const rangeDados = local.sheet.getRange(2, colIndex + 1, lastRow - 1, 3).getValues();
    
    const itensFormatados = rangeDados.map(row => {
      const textoPergunta = String(row[0] || "").trim();
      if (!textoPergunta) return null;

      return {
        pergunta: textoPergunta,
        tipoGatilho: String(row[1] || "").trim().toUpperCase(), // Coluna seguinte (ex: Q, S ou U)
        linkImagem: String(row[2] || "").trim()                 // Coluna seguinte (ex: R, T ou V)
      };
    }).filter(item => item !== null);

    return { itens: itensFormatados, tipo: tipo };
  } catch (e) { 
    return { erro: e.message }; 
  }
}

/**
 * SALVA A PREVENTIVA E CHAMA O ENVIO DE E-MAIL
 */
function salvarChecklistPreventiva(tecnico, maquina, tipo, respostas, tempo, ordemID) {
  try {
    const local = getMachineSheet(maquina);
    const targetSheet = local ? local.sheet : getSS().getSheetByName(maquina);
    
    // Extrai apenas os números para uso visual (E-mail e PDF)
    const numeroOrdemLimpo = extrairApenasNumeroOrdem(ordemID);
    
    // Adiciona o OrdemID Limpo dentro do JSON para amarrar com o Histórico e o PDF
    const jsonStr = JSON.stringify({ respostas: respostas, tempo: tempo, ordemID: numeroOrdemLimpo });
    targetSheet.appendRow([new Date(), tecnico, "PREVENTIVA", "Checklist " + tipo, "Concluída", jsonStr]);
    
    // --- LÓGICA DE ATUALIZAÇÃO DA PLANILHA DE ORDENS E LOG ---
    if (ordemID) {
        const ssOrdens = getSSOrdens();
        const tecUpper = tecnico.toUpperCase().trim();
        
        // Mapeamento de Times vs Abas
        const timeTeste = ["ODANIR", "ANDERSON", "CEZAR"];
        const timeSMT = ["DAYANNE", "FELIPE ALMEIDA", "OTNIEL", "RAINE", "ROGERIO", "ANSELMO", "WALMIR"];
        const timeFerramentaria = ["SELBERTHS"];
        
        let nomeAba = "MF+INJ"; // Default
        if (timeTeste.includes(tecUpper)) nomeAba = "TESTE";
        else if (timeSMT.includes(tecUpper)) nomeAba = "SMT";
        else if (timeFerramentaria.includes(tecUpper)) nomeAba = "MOLDE";
        
        const abaOrdens = ssOrdens.getSheetByName(nomeAba);
        if (abaOrdens) {
            const dadosO = abaOrdens.getDataRange().getValues();
            for (let i = 1; i < dadosO.length; i++) {
                // ATENÇÃO: Aqui mantemos a busca usando a string original "ordemID" pra garantir que a planilha bata
                if (String(dadosO[i][0]).trim() === String(ordemID).trim()) {
                    abaOrdens.getRange(i + 1, 7).setValue("CONFIRMADO"); // Coluna G
                    break;
                }
            }
        }
        
        // Preencher aba LOG
        const abaLog = ssOrdens.getSheetByName("LOG");
        if (abaLog) {
            const dataConclusao = Utilities.formatDate(new Date(), "GMT-3", "dd/MM/yyyy HH:mm:ss");
            abaLog.appendRow([
    new Date(), 
    ordemID,    
    tecnico,    
    nomeAba,    
    "", // Coluna E vazia
    "Checklist de manutenção preventiva"
]);
        }
    }

    // --- NOVA FUNÇÃO DE ENVIO DE E-MAIL PARA PREVENTIVA ---
    try {
        // Envia o e-mail passando a string "limpa" para não aparecer os parênteses feios
        enviarEmailPreventiva(tecnico, maquina, tipo, respostas, tempo, numeroOrdemLimpo);
    } catch (errEmail) {
        console.log("Erro no envio do e-mail de preventiva: " + errEmail.message);
    }

    return "Salvo com sucesso!";
  } catch (e) { return "Erro: " + e.message; }
}

