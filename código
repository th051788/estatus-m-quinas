/**
 * VALIDAÇÃO DE ACESSO POR SENHA
 */
function verificarSenhaTecnico(tecnico, senhaInformada) {
  try {
    const ss = getSS();
    const sheet = ss.getSheetByName("Página1");
    if (!sheet) return { sucesso: false, erro: "Aba de senhas não encontrada." };

    const dados = sheet.getDataRange().getValues();
    const tecnicoProcurado = tecnico.trim().toUpperCase();

    for (let i = 0; i < dados.length; i++) {
      const nomePlanilha = String(dados[i][0]).trim().toUpperCase();
      const senhaPlanilha = String(dados[i][1]).trim();

      if (nomePlanilha === tecnicoProcurado) {
        if (senhaPlanilha === String(senhaInformada).trim()) {
          return { sucesso: true };
        } else {
          return { sucesso: false, erro: "Senha incorreta!" };
        }
      }
    }
    return { sucesso: false, erro: "Técnico não cadastrado na lista de senhas." };
  } catch (e) {
    return { sucesso: false, erro: "Erro ao validar senha: " + e.message };
  }
}

/**
 * LISTAR MÁQUINAS COM LOCALIZAÇÃO (N2) E SUBÁREA (N3)
 * Agora retorna um objeto com metadados para montar os cards
 */
function listarMaquinas() {
  try {
    const namesToIgnore = ["LOG_SISTEMA", "REGISTROS_MANUTENCAO", "LOG_ACESSO", "MANUTENCOES", "Página1", "Sheet1", "REGISTROS_PREVENTIVA", "HISTORICO_CORRETIVAS", "DASHBOARD"];
    
    // Lista de planilhas para percorrer (Incluindo Ferramentaria)
    const planilhas = [getSS(), getSSSetup(), getSS_SMT(), getSS_TESTE(), getSS_FERRAMENTARIA()];
    
    let listaCompleta = [];

    planilhas.forEach(ss => {
        if(!ss) return;
        const sheets = ss.getSheets();
        
        sheets.forEach(s => {
            const nome = s.getName().trim();
            if (!namesToIgnore.includes(nome)) {
                // Tenta ler N2 e N3 para categorização
                let local = "Geral";
                let subarea = "";
                
                try {
                    const metaData = s.getRange("N2:N3").getValues();
                    if(metaData[0][0]) local = String(metaData[0][0]).trim();
                    if(metaData[1][0]) subarea = String(metaData[1][0]).trim();
                } catch(e) {}

                listaCompleta.push({
                    nome: nome,
                    area: local || "Outros",
                    subarea: subarea
                });
            }
        });
    });

    listaCompleta.sort((a, b) => {
        if (a.area < b.area) return -1;
        if (a.area > b.area) return 1;
        return a.nome.localeCompare(b.nome);
    });

    return listaCompleta;

  } catch (e) { 
      return [{nome: "Erro ao carregar", area: "Erro", subarea: ""}]; 
  }
}

